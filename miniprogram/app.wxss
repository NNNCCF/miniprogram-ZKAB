/* app.wxss — 全局样式 */
page {
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  background: #F5F6FA;
  box-sizing: border-box;
}

.blue-page {
  min-height: 100vh;
  background: #3B7EFF;
  display: flex;
  flex-direction: column;
}

.page-body {
  flex: 1;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  overflow: hidden;
}

.flex-col { display: flex; flex-direction: column; }
.flex-row { display: flex; flex-direction: row; }
.flex-1 { flex: 1; }

/* 通用输入框 */
.input-wrap {
  display: flex;
  align-items: center;
  background: #EEF3FB;
  border-radius: 16rpx;
  padding: 0 28rpx;
  height: 96rpx;
}
.input-wrap input {
  flex: 1;
  font-size: 28rpx;
  color: #1F2937;
  background: transparent;
}
.ph { color: #9CA3AF; }

/* 通用主按钮 */
.btn-primary {
  background: linear-gradient(135deg, #3B7EFF, #2060E0);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 100rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(59, 126, 255, 0.35);
}

/* 分割线 */
.divider { height: 1rpx; background: #F0F1F5; }

/* 空状态 */
.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: #BEC4D6;
  font-size: 28rpx;
}
