<view class="navbar">
  <view class="navbar-back" bindtap="goBack">
    <text class="navbar-back-icon">‹</text>
  </view>
  <text class="navbar-title">注册账号</text>
</view>

<view class="page-body">

  <view class="form-section">
    <!-- Phone -->
    <view class="field-group">
      <text class="field-label">手机号</text>
      <input
        class="field-input"
        type="number"
        placeholder="请输入手机号"
        maxlength="11"
        value="{{form.phone}}"
        bindinput="onInput"
        data-field="phone"
      />
    </view>

    <!-- Password -->
    <view class="field-group">
      <text class="field-label">密码</text>
      <input
        class="field-input"
        password="{{true}}"
        placeholder="请输入密码（6-20位）"
        value="{{form.password}}"
        bindinput="onInput"
        data-field="password"
      />
    </view>

    <!-- Confirm Password -->
    <view class="field-group">
      <text class="field-label">确认密码</text>
      <input
        class="field-input"
        password="{{true}}"
        placeholder="请再次输入密码"
        value="{{form.confirmPassword}}"
        bindinput="onInput"
        data-field="confirmPassword"
      />
    </view>

    <!-- Name -->
    <view class="field-group">
      <text class="field-label">姓名</text>
      <input
        class="field-input"
        placeholder="请输入真实姓名"
        value="{{form.name}}"
        bindinput="onInput"
        data-field="name"
      />
    </view>

    <!-- Role Selector -->
    <view class="field-group">
      <text class="field-label">角色</text>
      <view class="role-row">
        <view
          class="role-btn {{form.role === 'staff' ? 'role-active' : ''}}"
          bindtap="selectRole"
          data-role="staff"
        >
          <text>医护人员</text>
        </view>
        <view
          class="role-btn {{form.role === 'guardian' ? 'role-active' : ''}}"
          bindtap="selectRole"
          data-role="guardian"
        >
          <text>家属</text>
        </view>
      </view>
    </view>

    <!-- Org Code (staff only) -->
    <view class="field-group" wx:if="{{form.role === 'staff'}}">
      <text class="field-label">机构码</text>
      <input
        class="field-input"
        placeholder="请输入所属机构码"
        value="{{form.orgCode}}"
        bindinput="onInput"
        data-field="orgCode"
      />
    </view>
  </view>

  <button class="submit-btn {{submitting ? 'btn-disabled' : ''}}" bindtap="handleRegister" disabled="{{submitting}}">
    {{submitting ? '注册中...' : '立即注册'}}
  </button>

  <view class="login-link-row">
    <text class="login-link-text">已有账号？</text>
    <text class="login-link" bindtap="goBack">返回登录</text>
  </view>

</view>
