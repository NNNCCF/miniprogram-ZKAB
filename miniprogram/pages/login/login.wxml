<view class="page">
  <!-- Hero 区 -->
  <view class="hero">
    <text class="plus p1">+</text>
    <text class="plus p2">+</text>
    <text class="plus p3">+</text>
    <text class="plus p4">+</text>
    <text class="plus p5">+</text>
    <text class="plus p6">+</text>
    <image class="logo" src="/images/tab_home.png" mode="aspectFit" />
    <text class="app-name">欢迎来到卓凯安伴</text>
    <view class="badge-row">
      <text class="badge">{{roleText}}</text>
    </view>
  </view>

  <!-- 表单卡片 -->
  <view class="form-card">
    <!-- Tab 切换：医护 / 家属 -->
    <view class="tab-row">
      <view class="tab-item {{activeTab==='staff'?'active':''}}" bindtap="setTab" data-tab="staff">
        <text>医护登录</text>
      </view>
      <view class="tab-item {{activeTab==='guardian'?'active':''}}" bindtap="setTab" data-tab="guardian">
        <text>家属登录</text>
      </view>
    </view>

    <!-- 手机号 -->
    <view class="input-wrap">
      <text class="input-icon">📱</text>
      <input class="ipt" value="{{form.phone}}" bindinput="onInput" data-field="phone"
        type="number" maxlength="11" placeholder="请输入手机号码" placeholder-class="ph" />
    </view>

    <!-- 密码 -->
    <view class="input-wrap">
      <text class="input-icon">🔒</text>
      <input class="ipt" value="{{form.password}}" bindinput="onInput" data-field="password"
        password="{{!showPwd}}" placeholder="请输入密码" placeholder-class="ph" />
      <text class="eye-btn" bindtap="togglePwd">{{showPwd?'隐':'显'}}</text>
    </view>

    <!-- 验证码 -->
    <view class="input-wrap captcha-row">
      <input class="ipt captcha-ipt" value="{{form.captcha}}" bindinput="onInput" data-field="captcha"
        maxlength="4" placeholder="验证码" placeholder-class="ph" />
      <view class="captcha-box" bindtap="refreshCaptcha">
        <text wx:for="{{captcha}}" wx:key="index"
          style="color:{{item.color}};transform:rotate({{item.angle}}deg);font-size:34rpx;font-weight:700;font-family:serif;">
          {{item.ch}}
        </text>
      </view>
    </view>

    <view class="btn-primary" bindtap="handleLogin">登 录</view>

    <view class="link-row">
      <text class="link-text" bindtap="goRegister">还没有账号？去注册</text>
    </view>

    <view class="divider-row">
      <view class="div-line"></view>
      <text class="div-text">第三方登录</text>
      <view class="div-line"></view>
    </view>

    <view class="wechat-row" bindtap="wechatLogin">
      <text class="wechat-text">微信一键登录</text>
    </view>
  </view>
</view>
