<view class="page">

  <!-- Hero 区 -->
  <view class="hero">
    <!-- 背景图，不拉伸 -->
    <image class="hero-bg" src="/images/login_bg.png" mode="aspectFill" />
    <!-- 遮罩，保证文字可读 -->
    <view class="hero-mask"></view>

    <image class="logo" src="/images/logo.png" mode="aspectFit" />
    <text class="app-name">卓凯安伴</text>
    <text class="app-sub">专业养老关怀平台</text>
  </view>

  <!-- 表单卡片 -->
  <view class="form-card">

    <!-- Tab 切换：登录 / 注册 -->
    <view class="tab-row">
      <view class="tab-item {{activeTab==='login'?'active':''}}" bindtap="setTab" data-tab="login">
        <text>登录</text>
      </view>
      <view class="tab-item {{activeTab==='register'?'active':''}}" bindtap="setTab" data-tab="register">
        <text>注册</text>
      </view>
    </view>

    <!-- ===== 登录表单 ===== -->
    <block wx:if="{{activeTab==='login'}}">

      <view class="input-wrap">
        <image class="input-icon" src="/images/icon_phone.png" mode="aspectFit" />
        <input class="ipt" value="{{loginForm.phone}}" bindinput="onLoginInput" data-field="phone"
          type="number" maxlength="11" placeholder="请输入手机号码" placeholder-class="ph" />
      </view>

      <view class="input-wrap">
        <image class="input-icon" src="/images/icon_lock.png" mode="aspectFit" />
        <input class="ipt" value="{{loginForm.password}}" bindinput="onLoginInput" data-field="password"
          password="{{!showPwd}}" placeholder="请输入密码" placeholder-class="ph" />
        <image class="eye-icon" src="/images/{{showPwd ? 'icon_eye_on' : 'icon_eye_off'}}.png"
          mode="aspectFit" bindtap="togglePwd" />
      </view>


      <view class="btn-primary {{submitting?'btn-loading':''}}" bindtap="handleLogin">
        {{submitting ? '登录中...' : '登 录'}}
      </view>

      <view class="divider-row">
        <view class="div-line"></view>
        <text class="div-text">第三方登录</text>
        <view class="div-line"></view>
      </view>

      <view class="wechat-row" bindtap="wechatLogin">
        <image class="wechat-icon" src="/images/icon_wechat.png" mode="aspectFit" />
      </view>

    </block>

    <!-- ===== 注册表单 ===== -->
    <block wx:else>

      <view class="input-wrap">
        <image class="input-icon" src="/images/icon_phone.png" mode="aspectFit" />
        <input class="ipt" value="{{regForm.phone}}" bindinput="onRegInput" data-field="phone"
          type="number" maxlength="11" placeholder="请输入手机号码" placeholder-class="ph" />
      </view>

      <view class="input-wrap">
        <image class="input-icon" src="/images/icon_user.png" mode="aspectFit" />
        <input class="ipt" value="{{regForm.name}}" bindinput="onRegInput" data-field="name"
          placeholder="请输入真实姓名" placeholder-class="ph" />
      </view>

      <view class="input-wrap">
        <image class="input-icon" src="/images/icon_lock.png" mode="aspectFit" />
        <input class="ipt" value="{{regForm.password}}" bindinput="onRegInput" data-field="password"
          password="{{!showRegPwd}}" placeholder="请设置密码（6-20位）" placeholder-class="ph" />
        <image class="eye-icon" src="/images/{{showRegPwd ? 'icon_eye_on' : 'icon_eye_off'}}.png"
          mode="aspectFit" bindtap="toggleRegPwd" />
      </view>

      <view class="input-wrap">
        <image class="input-icon" src="/images/icon_lock.png" mode="aspectFit" />
        <input class="ipt" value="{{regForm.confirmPassword}}" bindinput="onRegInput" data-field="confirmPassword"
          password="{{!showRegPwd}}" placeholder="请再次输入密码" placeholder-class="ph" />
      </view>

      <!-- 角色选择 -->
      <view class="role-section">
        <text class="role-title">我的身份</text>
        <view class="role-row">
          <view class="role-btn {{regForm.role==='staff'?'role-active':''}}"
            bindtap="selectRole" data-role="staff">
            <image class="role-icon-img" src="/images/icon_medical.png" mode="aspectFit" />
            <text class="role-label">医护人员</text>
          </view>
          <view class="role-btn {{regForm.role==='guardian'?'role-active':''}}"
            bindtap="selectRole" data-role="guardian">
            <image class="role-icon-img" src="/images/icon_family.png" mode="aspectFit" />
            <text class="role-label">家属</text>
          </view>
        </view>
      </view>

      <!-- 机构选择（医护专属）-->
      <block wx:if="{{regForm.role==='staff'}}">
        <picker
          mode="selector"
          range="{{orgNames}}"
          value="{{orgIndex}}"
          bindchange="onOrgPickerChange"
          disabled="{{orgLoading || orgList.length === 0}}"
        >
          <view class="input-wrap org-picker-wrap">
            <image class="input-icon" src="/images/icon_building.png" mode="aspectFit" />
            <view class="org-picker-content">
              <text wx:if="{{orgLoading}}" class="ph">机构列表加载中...</text>
              <text wx:elif="{{orgList.length === 0}}" class="ph">暂无可用机构</text>
              <text wx:elif="{{orgIndex >= 0}}" class="org-selected-text">{{orgNames[orgIndex]}}</text>
              <text wx:else class="ph">请选择所属医疗机构</text>
            </view>
            <text class="picker-arrow">▾</text>
          </view>
        </picker>
        <!-- 选中机构显示地址 -->
        <view wx:if="{{orgIndex >= 0 && orgList[orgIndex].address}}" class="org-addr-tip">
          <text class="org-addr-text">📍 {{orgList[orgIndex].address}}</text>
        </view>
      </block>

      <view class="btn-primary {{submitting?'btn-loading':''}}" bindtap="handleRegister">
        {{submitting ? '注册中...' : '立即注册'}}
      </view>

    </block>

  </view>
</view>
