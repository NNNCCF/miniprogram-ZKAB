page {
  background: #1B3A70;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(160deg, #1B3A70 0%, #2B6BE0 50%, #3B7EFF 100%);
}

/* ===== Hero ===== */
.hero {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 48rpx;
  padding-bottom: 32rpx;
  overflow: hidden;
}

/* 背景图 */
.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* 渐变遮罩，保证 logo 和文字可读 */
.hero-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(160deg, rgba(27,58,112,0.55) 0%, rgba(43,107,224,0.45) 100%);
}

.logo {
  width: 500rpx;
  height: 500rpx;
  margin-bottom: -200;
  position: relative;
}

.app-name {
  font-family: 'HarmonyOS_Sans_SC', 'PingFang SC', 'Noto Sans SC', sans-serif;
  font-size: 46rpx;
  font-weight: 500;
  color: #fff;
  letter-spacing: 10rpx;
  position: relative;
}

.app-sub {
  font-family: 'HarmonyOS_Sans_SC', 'PingFang SC', 'Noto Sans SC', sans-serif;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  margin-top: 14rpx;
  letter-spacing: 4rpx;
  position: relative;
}

/* ===== Form Card ===== */
.form-card {
  flex: 1;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 40rpx calc(60rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  overflow-y: auto;
}

/* ===== Tab ===== */
.tab-row {
  display: flex;
  border-bottom: 1rpx solid #EEF2FA;
  margin-bottom: 12rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding-bottom: 22rpx;
  font-size: 30rpx;
  color: #9CA3B4;
  position: relative;
}

.tab-item.active {
  color: #1B3A70;
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -1rpx;
  left: 30%;
  right: 30%;
  height: 4rpx;
  background: #3B7EFF;
  border-radius: 4rpx;
}

/* ===== Input ===== */
.input-wrap {
  display: flex;
  align-items: center;
  background: #F2F5FC;
  border-radius: 23px;
  padding: 0 24rpx;
  height: 104rpx;
  gap: 20rpx;
}

.input-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  opacity: 0.45;
}

.ipt {
  flex: 1;
  font-size: 28rpx;
  color: #0F1C38;
  height: 96rpx;
}

.ph { color: #B0B8CC; }

.eye-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  opacity: 0.4;
}


/* ===== Role Section ===== */
.role-section {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.role-title {
  font-size: 24rpx;
  color: #8A94A8;
  letter-spacing: 1rpx;
}

.role-row {
  display: flex;
  gap: 16rpx;
}

.role-btn {
  flex: 1;
  height: 96rpx;
  border-radius: 24rpx;
  background: #F2F5FC;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 1rpx solid transparent;
  box-sizing: border-box;
}

.role-active {
  background: #EBF1FF;
  border-color: #3B7EFF;
}

.role-icon-img {
  width: 34rpx;
  height: 34rpx;
  opacity: 0.5;
}

.role-active .role-icon-img {
  opacity: 1;
}

.role-label {
  font-size: 28rpx;
  color: #4A587A;
}

.role-active .role-label {
  color: #2B6BE0;
  font-weight: 600;
}

/* ===== 机构选择 Picker ===== */
.org-picker-wrap {
  cursor: pointer;
}

.org-picker-content {
  flex: 1;
  display: flex;
  align-items: center;
}

.org-selected-text {
  font-size: 28rpx;
  color: #1B3A70;
}

.picker-arrow {
  font-size: 24rpx;
  color: #A0AABF;
  flex-shrink: 0;
}

.org-addr-tip {
  padding: 8rpx 24rpx 0;
}

.org-addr-text {
  font-size: 22rpx;
  color: #8A94A8;
}

/* ===== Button ===== */
.btn-primary {
  background: #38B6FF;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 100rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  letter-spacing: 6rpx;
  box-shadow: 0 8rpx 24rpx rgba(56, 182, 255, 0.35);
  margin-top: 8rpx;
}

.btn-loading {
  opacity: 0.65;
}

/* ===== Divider ===== */
.divider-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.div-line {
  flex: 1;
  height: 1rpx;
  background: #EEF2FA;
}

.div-text {
  font-size: 22rpx;
  color: #B0B8CC;
  white-space: nowrap;
  letter-spacing: 1rpx;
}

/* ===== WeChat ===== */
.wechat-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 6rpx 0;
}

.wechat-icon {
  width: 80rpx;
  height: 80rpx;
}
