page { background: #2060E0; }

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(160deg, #2060E0 0%, #3B7EFF 50%, #5B99FF 100%);
}

/* Hero */
.hero {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  padding-bottom: 80rpx;
}
.plus {
  position: absolute;
  color: rgba(255,255,255,0.2);
  font-weight: 700;
}
.p1 { top: 60rpx; left: 60rpx; font-size: 56rpx; }
.p2 { top: 100rpx; right: 80rpx; font-size: 40rpx; }
.p3 { top: 220rpx; left: 30rpx; font-size: 32rpx; }
.p4 { top: 200rpx; right: 40rpx; font-size: 64rpx; }
.p5 { top: 300rpx; left: 140rpx; font-size: 28rpx; }
.p6 { top: 280rpx; right: 160rpx; font-size: 36rpx; }

.logo {
  width: 200rpx; height: 200rpx;
  margin-bottom: 32rpx;
}
.app-name {
  font-size: 40rpx; font-weight: 700;
  color: #fff; letter-spacing: 4rpx;
}
.badge-row { margin-top: 16rpx; }
.badge {
  background: rgba(255,255,255,0.2);
  border: 2rpx solid rgba(255,255,255,0.5);
  color: #fff; font-size: 24rpx;
  padding: 6rpx 28rpx;
  border-radius: 100rpx;
  letter-spacing: 4rpx;
}

/* Form Card */
.form-card {
  flex: 1;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx;
  padding: 40rpx 40rpx 60rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* Tab */
.tab-row { display: flex; border-bottom: 2rpx solid #F0F1F5; margin-bottom: 8rpx; }
.tab-item { flex: 1; text-align: center; padding-bottom: 20rpx; font-size: 30rpx; color: #9CA3AF; position: relative; }
.tab-item.active { color: #3B7EFF; font-weight: 600; }
.tab-item.active::after {
  content: '';
  position: absolute; bottom: -2rpx; left: 20%; right: 20%;
  height: 4rpx; background: #3B7EFF; border-radius: 4rpx;
}

/* Input */
.input-wrap {
  display: flex; align-items: center;
  background: #EEF3FB; border-radius: 16rpx;
  padding: 0 28rpx; height: 96rpx;
}
.input-icon { font-size: 32rpx; margin-right: 16rpx; }
.ipt { flex: 1; font-size: 28rpx; color: #1F2937; height: 96rpx; }
.ph { color: #9CA3AF; }
.eye-btn { font-size: 24rpx; color: #3B7EFF; padding: 10rpx; }

/* Captcha */
.captcha-row { gap: 0; }
.captcha-ipt { flex: 1; }
.captcha-box {
  display: flex; align-items: center; justify-content: center;
  width: 180rpx; height: 72rpx;
  background: #fff; border-radius: 12rpx;
  border: 2rpx solid #E5E7EB;
  flex-shrink: 0; margin-left: 16rpx;
  padding: 0 12rpx;
}

/* Button */
.btn-primary {
  background: linear-gradient(135deg, #3B7EFF, #2060E0);
  color: #fff; font-size: 32rpx; font-weight: 600;
  border-radius: 100rpx; height: 96rpx; line-height: 96rpx;
  text-align: center; letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(59,126,255,0.35);
}

/* Links */
.link-row { display: flex; justify-content: center; }
.link-text { font-size: 26rpx; color: #3B7EFF; }

/* Divider */
.divider-row { display: flex; align-items: center; gap: 20rpx; }
.div-line { flex: 1; height: 1rpx; background: #E5E7EB; }
.div-text { font-size: 24rpx; color: #9CA3AF; white-space: nowrap; }

/* WeChat */
.wechat-row {
  display: flex; justify-content: center;
  padding: 8rpx 0;
}
.wechat-text { font-size: 28rpx; color: #07C160; font-weight: 600; }
