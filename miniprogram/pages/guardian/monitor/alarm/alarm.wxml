<view class="page">
  <view class="nav-bar" style="padding-top:{{statusH}}px;">
    <image class="header-bg" src="/images/nav_top_bg.png" mode="aspectFill" />
    <view class="nav-inner">
      <view class="nav-back" bindtap="goBack"><text class="back-arrow">←</text></view>
      <text class="nav-title">报警详情</text>
      <view style="width:60rpx;"></view>
    </view>
  </view>

  <scroll-view class="body-area" scroll-y>
    <view wx:if="{{loading}}" class="loading-wrap"><text class="loading-text">加载中...</text></view>

    <view wx:elif="{{alarm}}" class="content">
      <view class="status-card {{alarm.level === 'high' ? 'card-high' : alarm.level === 'medium' ? 'card-medium' : 'card-low'}}">
        <view class="status-icon-wrap"><text class="status-icon">{{alarm.level === 'high' ? '!' : 'i'}}</text></view>
        <view class="status-info">
          <text class="alarm-type">{{alarm.alarmType || '健康报警'}}</text>
          <text class="alarm-status-text">{{alarm.handleResultLabel || (alarm.status === 'unhandled' ? '待处理' : alarm.status)}}</text>
        </view>
        <view class="level-badge {{alarm.level === 'high' ? 'badge-high' : alarm.level === 'medium' ? 'badge-medium' : 'badge-low'}}"><text>{{alarm.levelLabel || '提醒'}}</text></view>
      </view>

      <view class="detail-card">
        <view class="detail-title">报警信息</view>
        <view class="detail-row"><text class="detail-key">报警类型</text><text class="detail-val">{{alarm.type || '--'}}</text></view>
        <view class="detail-row"><text class="detail-key">发生时间</text><text class="detail-val">{{alarm.alarmTime || '--'}}</text></view>
        <view class="detail-row"><text class="detail-key">成员姓名</text><text class="detail-val">{{alarm.memberName || '--'}}</text></view>
        <view class="detail-row"><text class="detail-key">发生位置</text><text class="detail-val">{{alarm.location || '--'}}</text></view>
        <view class="detail-row"><text class="detail-key">当前状态</text><text class="detail-val {{alarm.status === 'handled' || alarm.status === 'ignored' ? 'text-green' : 'text-red'}}">{{alarm.handleResultLabel || (alarm.status === 'unhandled' ? '待处理' : alarm.status)}}</text></view>
      </view>

      <view class="desc-card" wx:if="{{alarm.description}}">
        <view class="detail-title">说明</view>
        <text class="desc-text">{{alarm.description}}</text>
      </view>

      <view class="action-row" wx:if="{{alarm.status === 'unhandled'}}">
        <view class="handle-btn" bindtap="markIgnored"><text>忽略报警</text></view>
        <view class="call-btn" bindtap="callEmergency"><text>发起求助</text></view>
      </view>
    </view>

    <view wx:elif="{{!loading}}" class="empty-wrap"><text class="empty-text">暂无报警信息</text></view>
  </scroll-view>
</view>