<view class="page">
  <view class="nav-bar" style="padding-top:{{statusH}}px;">
    <image class="header-bg" src="/images/nav_top_bg.png" mode="aspectFill" />
    <view class="nav-inner">
      <view class="nav-back" bindtap="goBack"><text class="back-arrow">←</text></view>
      <text class="nav-title">健康监测</text>
      <view style="width:60rpx;"></view>
    </view>
  </view>

  <scroll-view class="body-area" scroll-y>
    <view class="realtime-row">
      <view class="realtime-card">
        <view class="rt-icon-wrap rt-blue"><image class="rt-icon" src="/images/icon_heartwave.png" mode="aspectFit" /></view>
        <view class="rt-info">
          <text class="rt-label">实时心率</text>
          <view class="rt-val-row"><text class="rt-val {{heartRateWarn ? 'val-warn' : ''}}">{{currentHeartRate}}</text><text class="rt-unit">bpm</text></view>
          <text class="rt-status {{heartRateWarn ? 'status-warn' : 'status-ok'}}">{{heartRateWarn ? '异常' : '正常'}}</text>
        </view>
      </view>
      <view class="realtime-card">
        <view class="rt-icon-wrap rt-green"><image class="rt-icon" src="/images/icon_sensor.png" mode="aspectFit" /></view>
        <view class="rt-info">
          <text class="rt-label">实时呼吸</text>
          <view class="rt-val-row"><text class="rt-val {{breathWarn ? 'val-warn' : ''}}">{{currentBreath}}</text><text class="rt-unit">次/分</text></view>
          <text class="rt-status {{breathWarn ? 'status-warn' : 'status-ok'}}">{{breathWarn ? '异常' : '正常'}}</text>
        </view>
      </view>
    </view>

    <view class="chart-card">
      <view class="chart-header">
        <text class="chart-title">{{memberName || '当前成员'}}近 7 天趋势</text>
        <view class="chart-tabs">
          <view class="chart-tab {{chartType === 'heartRate' ? 'ctab-active' : ''}}" bindtap="switchChart" data-type="heartRate">心率</view>
          <view class="chart-tab {{chartType === 'breathRate' ? 'ctab-active' : ''}}" bindtap="switchChart" data-type="breathRate">呼吸</view>
        </view>
      </view>
      <view class="chart-body">
        <view class="y-axis"><text wx:for="{{yLabels}}" wx:key="*this" class="y-label">{{item}}</text></view>
        <view class="canvas-wrap">
          <canvas canvas-id="lineChart" class="line-chart" style="width:{{canvasW}}px;height:{{canvasH}}px;"></canvas>
          <view class="x-axis"><text wx:for="{{xLabels}}" wx:key="*this" class="x-label">{{item}}</text></view>
        </view>
      </view>
    </view>

    <view class="history-card">
      <text class="section-title">历史记录</text>
      <view wx:if="{{loading}}" class="loading-wrap"><text class="loading-text">加载中...</text></view>
      <view wx:elif="{{historyList.length === 0}}" class="empty-wrap"><text class="empty-text">暂无记录</text></view>
      <block wx:else>
        <view class="history-item" wx:for="{{historyList}}" wx:key="id">
          <view class="item-left"><text class="item-date">{{item.date}}</text><text class="item-time">{{item.time}}</text></view>
          <view class="item-data">
            <view class="data-row"><text class="data-label">心率</text><text class="data-val {{item.heartRateWarn ? 'val-warn' : ''}}">{{item.heartRate}} bpm</text></view>
            <view class="data-row"><text class="data-label">呼吸</text><text class="data-val">{{item.breath}} 次/分</text></view>
          </view>
          <view class="item-badge {{item.warn ? 'badge-warn' : 'badge-ok'}}"><text>{{item.warn ? '异常' : '正常'}}</text></view>
        </view>
      </block>
    </view>
  </scroll-view>
</view>