page { background: #EEF2FF; height: 100vh; overflow: hidden; }
.page { height: 100vh; display: flex; flex-direction: column; background: #EEF2FF; }

/* ===== Nav Bar ===== */
.nav-bar {
  position: relative;
  overflow: hidden;
  height: 136rpx;
  flex-shrink: 0;
}
.header-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.nav-inner {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  position: relative;
  z-index: 1;
}
.nav-back { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; }
.back-arrow { font-size: 52rpx; color: #fff; line-height: 1; }
.nav-title { font-size: 34rpx; font-weight: 700; color: #fff; }

/* ===== Body Area ===== */
.body-area {
  flex: 1;
  background: #F2F5FC;
  border-radius: 28rpx 28rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  overflow-y: auto;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

/* ===== Realtime Row ===== */
.realtime-row {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 24rpx 0;
}
.realtime-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(43, 107, 224, 0.08);
}
.rt-icon-wrap {
  width: 72rpx; height: 72rpx;
  border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.rt-blue { background: #EBF1FF; }
.rt-green { background: #ECFDF5; }
.rt-icon { width: 40rpx; height: 40rpx; }
.rt-info { flex: 1; }
.rt-label { display: block; font-size: 22rpx; color: #9CA3B4; margin-bottom: 4rpx; }
.rt-val-row { display: flex; align-items: baseline; gap: 4rpx; }
.rt-val { font-size: 40rpx; font-weight: 800; color: #0F1C38; line-height: 1.1; }
.rt-unit { font-size: 20rpx; color: #9CA3B4; }
.val-warn { color: #E63A35; }
.rt-status { display: block; font-size: 20rpx; margin-top: 4rpx; }
.status-ok { color: #10B981; }
.status-warn { color: #E63A35; }

/* ===== Chart Card ===== */
.chart-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 16rpx 24rpx 0;
  padding: 24rpx 20rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(43, 107, 224, 0.08);
}
.chart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.chart-title { font-size: 28rpx; font-weight: 700; color: #0F1C38; }
.chart-tabs { display: flex; gap: 0; background: #F2F5FC; border-radius: 12rpx; overflow: hidden; }
.chart-tab {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #9CA3B4;
}
.ctab-active {
  background: #3B7EFF;
  color: #fff;
  border-radius: 12rpx;
  font-weight: 600;
}

.chart-body { display: flex; align-items: flex-start; }
.y-axis {
  width: 48rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 160px;
  padding: 8px 0;
  flex-shrink: 0;
}
.y-label { font-size: 18rpx; color: #C0C8D8; text-align: right; display: block; }
.canvas-wrap { flex: 1; display: flex; flex-direction: column; }
.line-chart { display: block; }
.x-axis {
  display: flex;
  justify-content: space-between;
  padding: 0 4rpx;
  margin-top: 8rpx;
}
.x-label { font-size: 18rpx; color: #C0C8D8; }

/* ===== History Card ===== */
.history-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 16rpx 24rpx 0;
  padding: 24rpx 24rpx 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(43, 107, 224, 0.08);
}
.section-title { display: block; font-size: 28rpx; font-weight: 700; color: #0F1C38; margin-bottom: 16rpx; }

.loading-wrap, .empty-wrap {
  padding: 48rpx 0;
  display: flex;
  justify-content: center;
}
.loading-text, .empty-text { font-size: 26rpx; color: #C0C8D8; }

.history-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F2F5FC;
}
.history-item:last-child { border-bottom: none; }
.item-left { flex-shrink: 0; width: 88rpx; }
.item-date { display: block; font-size: 22rpx; color: #9CA3B4; }
.item-time { display: block; font-size: 26rpx; font-weight: 700; color: #374151; margin-top: 4rpx; }
.item-data { flex: 1; }
.data-row { display: flex; gap: 12rpx; align-items: center; margin-bottom: 6rpx; }
.data-row:last-child { margin-bottom: 0; }
.data-label { font-size: 22rpx; color: #9CA3B4; width: 56rpx; }
.data-val { font-size: 26rpx; font-weight: 600; color: #0F1C38; }

.item-badge {
  flex-shrink: 0;
  border-radius: 20rpx;
  padding: 6rpx 18rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.badge-ok { background: #ECFDF5; color: #10B981; }
.badge-warn { background: #FEF2F2; color: #E63A35; }
