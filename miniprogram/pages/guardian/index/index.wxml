<view class="page">
  <view class="header" style="padding-top:{{statusH}}px;">
    <image class="header-bg" src="/images/nav_top_bg.png" mode="aspectFill" />
    <view class="header-inner">
      <image class="brand-logo" src="/images/g-logo.png" mode="aspectFit" />

      <view wx:if="{{!hasMember}}" class="unbound-badge" bindtap="goBindDevice">
        <text class="unbound-text">未绑定设备</text>
      </view>

      <view wx:else class="member-chip" bindtap="goSwitch">
        <view class="member-avatar-sm">
          <text class="member-initial">{{member.name ? member.name[0] : '?'}}</text>
        </view>
        <text class="member-chip-name">{{member.name || '--'}}</text>
        <text class="chip-arrow">></text>
      </view>
    </view>
  </view>

  <view class="card-area">
    <block wx:if="{{!hasMember}}">
      <view class="bind-entry" bindtap="goBindDevice">
        <view class="bind-main">
          <view class="bind-plus-btn"><text class="plus-text">+</text></view>
          <view class="bind-info-wrap">
            <text class="bind-title">设备绑定</text>
            <text class="bind-sub">设备绑定后才可创建成员与查看监测数据</text>
          </view>
        </view>
        <view class="feature-hint">
          <text class="hint-desc">绑定完成后，可查看心率、呼吸、活动状态与跌倒报警。</text>
          <view class="feat-icon-row">
            <image class="feat-icon" src="/images/icon_sensor.png" mode="aspectFit" />
            <image class="feat-icon" src="/images/icon_heartwave.png" mode="aspectFit" />
            <image class="feat-icon" src="/images/icon_walk.png" mode="aspectFit" />
            <image class="feat-icon" src="/images/icon_fall.png" mode="aspectFit" />
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
      <scroll-view scroll-y class="data-scroll">
        <view class="metric-card">
          <image class="metric-panel-bg" src="/images/heart-panel.png" mode="aspectFit" />
          <view class="metric-header">
            <text class="metric-name">呼吸频率</text>
            <view class="status-chip {{breathHistory.isWarn ? 'chip-warn' : 'chip-ok'}}"><text>{{breathHistory.status || '正常'}}</text></view>
            <text class="history-link" bindtap="goBreathHistory">历史记录</text>
          </view>
          <canvas canvas-id="breathChart" id="breathChart" style="width:{{chartW}}px;height:80px;" class="chart-canvas"></canvas>
          <view class="time-bar">
            <text class="time-label">{{breathHistory.startTime || '00:00'}}</text>
            <text class="time-label">{{breathHistory.endTime || '--:--'}}</text>
          </view>
          <view class="metric-divider"></view>
          <view class="stats-row">
            <view class="stat-block"><text class="stat-label">平均</text><view class="stat-val-row"><text class="stat-val">{{breathHistory.avg || '--'}}</text><text class="stat-unit">次/分</text></view></view>
            <view class="stat-block"><text class="stat-label">最高</text><view class="stat-val-row"><text class="stat-val">{{breathHistory.max || '--'}}</text><text class="stat-unit">次/分</text></view></view>
            <view class="stat-block"><text class="stat-label">最低</text><view class="stat-val-row"><text class="stat-val">{{breathHistory.min || '--'}}</text><text class="stat-unit">次/分</text></view></view>
          </view>
        </view>

        <view class="metric-card">
          <image class="metric-panel-bg" src="/images/heart-panel.png" mode="aspectFit" />
          <view class="metric-header">
            <text class="metric-name">心率</text>
            <view class="status-chip {{heartHistory.isWarn ? 'chip-warn' : 'chip-ok'}}"><text>{{heartHistory.status || '正常'}}</text></view>
            <text class="history-link" bindtap="goHeartHistory">历史记录</text>
          </view>
          <canvas canvas-id="heartChart" id="heartChart" style="width:{{chartW}}px;height:80px;" class="chart-canvas"></canvas>
          <view class="time-bar">
            <text class="time-label">{{heartHistory.startTime || '00:00'}}</text>
            <text class="time-label">{{heartHistory.endTime || '--:--'}}</text>
          </view>
          <view class="metric-divider"></view>
          <view class="stats-row">
            <view class="stat-block"><text class="stat-label">平均</text><view class="stat-val-row"><text class="stat-val">{{heartHistory.avg || '--'}}</text><text class="stat-unit">bpm</text></view></view>
            <view class="stat-block"><text class="stat-label">最高</text><view class="stat-val-row"><text class="stat-val">{{heartHistory.max || '--'}}</text><text class="stat-unit">bpm</text></view></view>
            <view class="stat-block"><text class="stat-label">最低</text><view class="stat-val-row"><text class="stat-val">{{heartHistory.min || '--'}}</text><text class="stat-unit">bpm</text></view></view>
          </view>
        </view>

        <view class="mini-row">
          <view class="mini-card" bindtap="goLatestAlarm">
            <view class="mini-card-info">
              <text class="mini-title">跌倒报警</text>
              <view class="status-chip {{vitals.fallStatus ? 'chip-warn' : 'chip-ok'}}"><text>{{vitals.fallStatus ? '报警中' : '正常'}}</text></view>
            </view>
            <image class="mini-icon" src="/images/icon_fall.png" mode="aspectFit" />
          </view>
          <view class="mini-card">
            <view class="mini-card-info">
              <text class="mini-title">活动状态</text>
              <view class="status-chip chip-ok"><text>{{vitals.activityStatus || '正常'}}</text></view>
            </view>
            <image class="mini-icon" src="/images/icon_walk.png" mode="aspectFit" />
          </view>
        </view>

        <view style="height:20rpx;"></view>
      </scroll-view>
    </block>
  </view>

  <view class="slogan-wrap"><text class="slogan">守护长辈安康</text></view>
  <guardian-tabbar active="home"></guardian-tabbar>
</view>