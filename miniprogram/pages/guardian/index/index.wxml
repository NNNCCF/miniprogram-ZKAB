<view class="page">
  <!-- Status Bar Placeholder -->
  <view style="height:{{statusH}}px;background:#3B7EFF;"></view>

  <!-- Header -->
  <view class="header">
    <text class="header-title">健康守护</text>
    <view class="header-right" bindtap="goNotification">
      <image class="bell-icon" src="/images/bell.png" mode="aspectFit"/>
    </view>
  </view>

  <!-- Member Health Card -->
  <view class="health-card">
    <view class="card-top">
      <view class="avatar-wrap">
        <text class="avatar-text">{{member.name ? member.name[0] : '?'}}</text>
      </view>
      <view class="card-info">
        <text class="member-name">{{member.name || '暂无成员'}}</text>
        <text class="member-age">{{member.age ? member.age + '岁' : '--'}} · {{member.relationship || ''}}</text>
      </view>
      <view class="status-badge {{member.status === 'normal' ? 'badge-normal' : 'badge-warn'}}">
        <text>{{member.status === 'normal' ? '正常' : '预警'}}</text>
      </view>
    </view>
    <view class="card-divider"></view>
    <view class="card-vitals">
      <view class="vital-item">
        <text class="vital-val">{{vitals.heartRate || '--'}}</text>
        <text class="vital-label">心率 bpm</text>
      </view>
      <view class="vital-sep"></view>
      <view class="vital-item">
        <text class="vital-val">{{vitals.systolic || '--'}}/{{vitals.diastolic || '--'}}</text>
        <text class="vital-label">血压 mmHg</text>
      </view>
      <view class="vital-sep"></view>
      <view class="vital-item">
        <text class="vital-val">{{vitals.steps || '--'}}</text>
        <text class="vital-label">步数</text>
      </view>
    </view>
  </view>

  <!-- Quick Actions -->
  <view class="quick-actions">
    <view class="action-item" bindtap="goHistory">
      <view class="action-icon-wrap blue">
        <text class="action-icon">📊</text>
      </view>
      <text class="action-label">历史记录</text>
    </view>
    <view class="action-item" bindtap="goSwitch">
      <view class="action-icon-wrap green">
        <text class="action-icon">👥</text>
      </view>
      <text class="action-label">人员切换</text>
    </view>
    <view class="action-item" bindtap="goService">
      <view class="action-icon-wrap orange">
        <text class="action-icon">🏥</text>
      </view>
      <text class="action-label">预约服务</text>
    </view>
    <view class="action-item" bindtap="goBindDevice">
      <view class="action-icon-wrap purple">
        <text class="action-icon">📡</text>
      </view>
      <text class="action-label">绑定设备</text>
    </view>
  </view>

  <!-- Real-time Data Section -->
  <view class="section-title">实时健康数据</view>
  <view class="realtime-list">
    <view class="realtime-item">
      <view class="realtime-left">
        <text class="realtime-icon">❤️</text>
        <view>
          <text class="realtime-name">心率</text>
          <text class="realtime-time">{{vitals.updateTime || '刚刚更新'}}</text>
        </view>
      </view>
      <view class="realtime-right">
        <text class="realtime-value {{vitals.heartRateStatus === 'warn' ? 'value-warn' : ''}}">{{vitals.heartRate || '--'}} <text class="realtime-unit">bpm</text></text>
      </view>
    </view>
    <view class="realtime-item">
      <view class="realtime-left">
        <text class="realtime-icon">🩸</text>
        <view>
          <text class="realtime-name">血压</text>
          <text class="realtime-time">{{vitals.updateTime || '刚刚更新'}}</text>
        </view>
      </view>
      <view class="realtime-right">
        <text class="realtime-value {{vitals.bpStatus === 'warn' ? 'value-warn' : ''}}">{{vitals.systolic || '--'}}/{{vitals.diastolic || '--'}} <text class="realtime-unit">mmHg</text></text>
      </view>
    </view>
    <view class="realtime-item">
      <view class="realtime-left">
        <text class="realtime-icon">🚶</text>
        <view>
          <text class="realtime-name">今日步数</text>
          <text class="realtime-time">{{vitals.updateTime || '刚刚更新'}}</text>
        </view>
      </view>
      <view class="realtime-right">
        <text class="realtime-value">{{vitals.steps || '--'}} <text class="realtime-unit">步</text></text>
      </view>
    </view>
    <view class="realtime-item">
      <view class="realtime-left">
        <text class="realtime-icon">🌡️</text>
        <view>
          <text class="realtime-name">体温</text>
          <text class="realtime-time">{{vitals.updateTime || '刚刚更新'}}</text>
        </view>
      </view>
      <view class="realtime-right">
        <text class="realtime-value">{{vitals.temperature || '--'}} <text class="realtime-unit">°C</text></text>
      </view>
    </view>
  </view>

  <!-- Tabbar -->
  <guardian-tabbar active="home"></guardian-tabbar>
</view>
