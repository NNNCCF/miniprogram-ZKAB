.page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 140rpx;
}

/* Header */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #3B7EFF;
}
.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}
.header-right { padding: 8rpx; }
.bell-icon { width: 44rpx; height: 44rpx; }

/* Health Card */
.health-card {
  margin: 24rpx 24rpx 0;
  background: linear-gradient(135deg, #3B7EFF 0%, #2563EB 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(59,126,255,0.25);
}
.card-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.avatar-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.avatar-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}
.card-info {
  flex: 1;
}
.member-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}
.member-age {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 6rpx;
}
.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.badge-normal {
  background: rgba(52,211,153,0.25);
  color: #6EE7B7;
}
.badge-warn {
  background: rgba(252,211,77,0.25);
  color: #FCD34D;
}
.card-divider {
  height: 1rpx;
  background: rgba(255,255,255,0.2);
  margin: 24rpx 0;
}
.card-vitals {
  display: flex;
  align-items: center;
}
.vital-item {
  flex: 1;
  text-align: center;
}
.vital-val {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}
.vital-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 6rpx;
}
.vital-sep {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.2);
}

/* Quick Actions */
.quick-actions {
  display: flex;
  justify-content: space-around;
  background: #fff;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 32rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.action-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.action-icon-wrap.blue { background: #EEF3FF; }
.action-icon-wrap.green { background: #ECFDF5; }
.action-icon-wrap.orange { background: #FFF7ED; }
.action-icon-wrap.purple { background: #F5F3FF; }
.action-label {
  font-size: 24rpx;
  color: #4B5563;
}

/* Section Title */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  padding: 32rpx 32rpx 16rpx;
}

/* Realtime List */
.realtime-list {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.realtime-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F3F4F6;
}
.realtime-item:last-child { border-bottom: none; }
.realtime-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.realtime-icon { font-size: 40rpx; }
.realtime-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}
.realtime-time {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}
.realtime-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}
.realtime-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: #9CA3AF;
}
.value-warn { color: #EF4444; }
