/* ===== 整体页面 ===== */
page {
  background: #EEF2FF;
  height: 100vh;
  overflow: hidden;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #EEF2FF;
}

/* ===== 头部（背景图） ===== */
.header {
  flex-shrink: 0;
  height: 248rpx;
  padding: 0 32rpx;
  position: relative;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.header-inner {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  position: relative;
  z-index: 1;
}

/* logo 绝对定位，不参与 flex 流，不影响 header 高度 */
.brand-logo {
  position: absolute;
  left: 30rpx;
  top: 50%;
  transform: translateY(-30%);
  width: 300rpx;
  height: 300rpx;
}

/* 未绑定 badge */
.unbound-badge {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 40rpx;
  padding: 10rpx 28rpx;
}

.unbound-text {
  font-size: 26rpx;
  color: #5B7FFF;
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* 成员选择器 */
.member-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 40rpx;
  padding: 8rpx 20rpx 8rpx 8rpx;
}

.member-avatar-sm {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #5B7FFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-initial {
  font-size: 22rpx;
  color: #fff;
  font-weight: 700;
}

.member-chip-name {
  font-size: 26rpx;
  color: #1B3A70;
  font-weight: 600;
  max-width: 120rpx;
}

.chip-arrow {
  font-size: 20rpx;
  color: #5B7FFF;
}

/* ===== 白色卡片区域 ===== */
.card-area {
  flex: 1;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  min-height: 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
}

/* ===== 空状态：设备绑定入口 ===== */
.bind-entry {
  margin: 32rpx 28rpx 0;
  background: linear-gradient(145deg, #6B8EFF 0%, #5B7FFF 100%);
  border-radius: 24rpx;
  overflow: hidden;
}

.bind-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 28rpx 24rpx;
}

.bind-plus-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.plus-text {
  font-size: 52rpx;
  color: #fff;
  line-height: 1;
  font-weight: 300;
}

.bind-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}

.bind-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
}

.feature-hint {
  background: rgba(255, 255, 255, 0.18);
  padding: 24rpx 28rpx;
}

.hint-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.feat-icon-row {
  display: flex;
  justify-content: space-around;
}

.feat-icon {
  width: 64rpx;
  height: 64rpx;
  opacity: 0.9;
}

.feat-icon-ph {
  font-size: 48rpx;
  opacity: 0.85;
}

/* ===== 有成员：数据滚动区 ===== */
.data-scroll {
  flex: 1;
  height: 100%;
  padding: 20rpx 24rpx 0;
  box-sizing: border-box;
}

/* ===== 监控数据卡片 ===== */
.metric-card {
  border-radius: 20rpx;
  padding: 24rpx 24rpx 20rpx;
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
}

.metric-panel-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.metric-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.chart-canvas,
.time-bar,
.metric-divider,
.stats-row {
  position: relative;
  z-index: 1;
}

.metric-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1B3A70;
  flex-shrink: 0;
}

.status-chip {
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.chip-ok {
  background: rgba(22, 193, 130, 0.05);
  color: #16C182;
}

.chip-warn {
  background: rgba(230, 58, 53, 0.10);
  color: #E63A35;
}

.history-link {
  margin-left: auto;
  font-size: 24rpx;
  color: #9CA8C8;
}

/* Canvas 图表 */
.chart-canvas {
  display: block;
  border-radius: 8rpx;
}

.time-bar {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  margin-bottom: 16rpx;
}

.time-label {
  font-size: 22rpx;
  color: #A0A8C0;
}

.metric-divider {
  height: 1rpx;
  background: rgba(100, 140, 255, 0.15);
  margin-bottom: 16rpx;
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #9CA8C0;
}

.stat-val-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.stat-val {
  font-size: 40rpx;
  font-weight: 700;
  color: #1B3A70;
  letter-spacing: -1rpx;
}

.stat-unit {
  font-size: 20rpx;
  color: #9CA8C0;
}

/* ===== 小卡片：跌倒 + 行动 ===== */
.mini-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.mini-card {
  flex: 1;
  background: linear-gradient(145deg, #EEF3FF 0%, #F0F4FF 100%);
  border-radius: 20rpx;
  padding: 24rpx 20rpx 20rpx;
  min-height: 160rpx;
  overflow: hidden;
  position: relative;
  border: 1rpx solid rgba(100, 140, 255, 0.12);
}

.mini-card-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  position: relative;
  z-index: 1;
}

.mini-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1B3A70;
}

.mini-bg-panel {
  position: absolute;
  right: -10rpx;
  bottom: -10rpx;
  width: 120rpx;
  height: 120rpx;
  opacity: 0.35;
}

.mini-icon {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  width: 72rpx;
  height: 72rpx;
  opacity: 0.75;
  z-index: 1;
}

.mini-icon-ph {
  position: absolute;
  right: 20rpx;
  bottom: 16rpx;
  font-size: 56rpx;
  opacity: 0.6;
  z-index: 1;
}

/* ===== 底部标语 ===== */
.slogan-wrap {
  position: fixed;
  bottom: calc(96rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 64rpx;
  pointer-events: none;
  background: #fff;
}

.slogan {
  font-size: 32rpx;
  color: #5B7FFF;
  font-style: italic;
  font-weight: 600;
  letter-spacing: 3rpx;
  border-bottom: 3rpx solid rgba(91, 127, 255, 0.4);
  padding-bottom: 4rpx;
}
