page {
  background: #EEF2FF;
  height: 100vh;
  overflow: hidden;
}
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #EEF2FF;
}

/* Header */
.header {
  flex-shrink: 0;
  height: 100rpx;
  position: relative;
  overflow: hidden;
}
.header-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
}
.header-inner {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}
.back-btn {
  position: absolute;
  left: 24rpx;
  padding: 12rpx 20rpx;
}
.back-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}
.header-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  letter-spacing: 2rpx;
  transform: translateY(-30rpx);
}

/* Body */
.body-area {
  flex: 1;
  background: #EEF2FF;
  margin-top: -32rpx;
  border-radius: 28rpx 28rpx 0 0;
  position: relative;
  z-index: 2;
  padding: 16rpx 16rpx 40rpx;
  box-sizing: border-box;
}

/* State */
.state-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.state-text {
  font-size: 28rpx;
  color: #9CA3AF;
}

/* Cancelled Banner */
.cancelled-banner {
  background: #FEE2E2;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cancelled-text {
  font-size: 28rpx;
  color: #EF4444;
  font-weight: 600;
}

/* Section */
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 24rpx;
}

/* ===== Progress Bar ===== */
.progress-section {
  padding-bottom: 24rpx;
}
.progress-track-wrap {
  position: relative;
  padding: 4rpx 0 0;
}

/* Dots row */
.dots-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 2;
  padding: 0 22rpx;
}
.dot-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}
.p-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #D1D5DB;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.3s;
}
.dot-active {
  background: #3B7EFF;
}
.dot-cur {
  background: #3B7EFF;
  box-shadow: 0 0 0 8rpx rgba(59, 126, 255, 0.18);
}
.dot-check {
  font-size: 22rpx;
  color: #fff;
  font-weight: 700;
}

/* Track line */
.track-bg {
  position: absolute;
  top: 26rpx;
  left: calc(22rpx + 22rpx);
  right: calc(22rpx + 22rpx);
  height: 4rpx;
  background: #E5E7EB;
  z-index: 1;
  border-radius: 2rpx;
}
.track-fill {
  height: 100%;
  background: #3B7EFF;
  border-radius: 2rpx;
  transition: width 0.4s ease;
}

/* Labels row */
.labels-row {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
  padding: 0 0rpx;
}
.label-wrap {
  flex: 1;
  display: flex;
  justify-content: center;
}
.p-label {
  font-size: 18rpx;
  color: #9CA3AF;
  text-align: center;
  line-height: 1.5;
  max-width: 80rpx;
}
.label-done {
  color: #3B7EFF;
}
.label-cur {
  color: #3B7EFF;
  font-weight: 700;
}

/* Step description */
.step-desc {
  margin-top: 20rpx;
  background: #EEF3FF;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}
.step-desc-text {
  font-size: 24rpx;
  color: #6B7280;
}
.step-desc-text.done {
  color: #10B981;
  font-weight: 600;
}

/* Info Card */
.info-card {
  background: #F8FAFF;
  border-radius: 16rpx;
  padding: 8rpx 20rpx;
}
.info-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #EFF2FA;
  gap: 16rpx;
}
.info-row:last-child {
  border-bottom: none;
}
.req-row {
  align-items: flex-start;
}
.info-label {
  font-size: 26rpx;
  color: #9CA3AF;
  width: 128rpx;
  flex-shrink: 0;
}
.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #374151;
  text-align: right;
}
.req-value {
  text-align: left;
  line-height: 1.6;
  white-space: pre-wrap;
}

/* Nurse Card */
.nurse-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #F8FAFF;
  border-radius: 16rpx;
  padding: 24rpx;
}
.nurse-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5B7FFF 0%, #3B6EF0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(59, 110, 240, 0.3);
}
.nurse-avatar-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}
.nurse-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.nurse-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}
.nurse-phone {
  font-size: 26rpx;
  color: #6B7280;
}
.no-phone {
  color: #C4C9D4;
}
.call-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  background: #EEF3FF;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  flex-shrink: 0;
}
.call-icon {
  font-size: 36rpx;
}
.call-text {
  font-size: 22rpx;
  color: #3B7EFF;
  font-weight: 600;
}
