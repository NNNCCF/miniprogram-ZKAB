<view class="page">
  <block wx:if="{{mode === 'profile'}}">
    <view class="hero" style="padding-top:{{statusH}}px;">
      <view class="nav-row">
        <view class="nav-back" bindtap="goBack"><text class="back-arrow">←</text></view>
        <text class="nav-title">服务医生</text>
        <view style="width:60rpx;"></view>
      </view>
      <view class="avatar-wrap">
        <view class="avatar-circle"><text class="avatar-emoji">医</text></view>
      </view>
      <text class="doctor-name">{{doctor.name || '暂未绑定'}}</text>
      <view class="org-pill">
        <text class="org-pill-text">{{doctor.institution || doctor.hospital || doctor.title || '服务人员'}}</text>
      </view>
    </view>

    <scroll-view scroll-y class="profile-body">
      <view class="contact-row">
        <view class="contact-btn contact-btn-green" bindtap="callDoctor">
          <text class="contact-icon">电话</text>
          <text class="contact-label">联系服务人员</text>
        </view>
        <view class="contact-btn contact-btn-blue" bindtap="callOrg">
          <text class="contact-icon">机构</text>
          <text class="contact-label">联系所属机构</text>
        </view>
      </view>

      <view class="profile-section">
        <text class="profile-section-title">服务说明</text>
        <text class="profile-section-content">{{doctor.specialty || '支持上门探访、预约体检、护理服务等家庭照护场景。如需安排时间，可在服务页直接发起预约。'}}</text>
      </view>

      <view class="tags-wrap">
        <view class="tag-item" wx:for="{{doctor.tags || ['上门探访', '预约体检', '护理服务', '健康咨询']}}" wx:key="*this">
          <text class="tag-text">{{item}}</text>
        </view>
      </view>
    </scroll-view>
  </block>

  <block wx:else>
    <view class="nav-bar" style="padding-top:{{statusH}}px;">
      <image class="header-bg" src="/images/nav_top_bg.png" mode="aspectFill" />
      <view class="nav-inner">
        <view class="nav-back" bindtap="goBack"><text class="back-arrow">←</text></view>
        <text class="nav-title">{{apptType}}</text>
        <view style="width:60rpx;"></view>
      </view>
    </view>

    <scroll-view class="book-body" scroll-y>
      <view class="doctor-mini-card">
        <view class="mini-avatar"><text class="mini-avatar-text">医</text></view>
        <view class="mini-info">
          <text class="mini-name">{{doctor.name || '服务人员待分配'}}</text>
          <text class="mini-title">{{doctor.institution || doctor.hospital || doctor.title || '机构统一安排'}}</text>
        </view>
      </view>

      <view class="book-section" wx:if="{{members.length}}">
        <text class="book-section-title">服务对象</text>
        <view class="book-card">
          <picker mode="selector" range="{{members}}" range-key="name" value="{{selectedMemberIndex}}" bindchange="onMemberChange">
            <view class="book-row">
              <text class="book-label">当前成员</text>
              <view class="book-row-right">
                <text class="book-val">{{members[selectedMemberIndex] ? members[selectedMemberIndex].name : '请选择'}}</text>
                <text class="book-arrow">></text>
              </view>
            </view>
          </picker>
        </view>
      </view>

      <view class="book-section" wx:if="{{itemList.length}}">
        <text class="book-section-title">选择服务项目</text>
        <view class="items-grid">
          <view class="item-chip {{selectedItems.indexOf(item.key) >= 0 ? 'item-chip-active' : ''}}" wx:for="{{itemList}}" wx:key="key" bindtap="toggleItem" data-key="{{item.key}}">
            <text class="item-chip-text">{{item.label}}</text>
          </view>
        </view>
        <text class="items-hint">已选 {{selectedItems.length}} 项</text>
      </view>

      <view class="book-section">
        <text class="book-section-title">预约时间</text>
        <view class="book-card">
          <picker mode="date" value="{{apptDate}}" start="{{minDate}}" bindchange="onDateChange">
            <view class="book-row">
              <text class="book-label">预约日期</text>
              <view class="book-row-right">
                <text class="book-val">{{apptDate}}</text>
                <text class="book-arrow">></text>
              </view>
            </view>
          </picker>
          <view class="book-divider"></view>
          <picker mode="time" value="{{apptTime}}" start="08:00" end="20:00" bindchange="onTimeChange">
            <view class="book-row">
              <text class="book-label">预约时间</text>
              <view class="book-row-right">
                <text class="book-val time-val">{{apptTime}}</text>
                <text class="book-arrow">></text>
              </view>
            </view>
          </picker>
        </view>
      </view>

      <view class="book-section">
        <text class="book-section-title">联系信息</text>
        <view class="book-card">
          <view class="book-row">
            <text class="book-label">联系人</text>
            <input class="book-input" placeholder="请填写联系人姓名" value="{{patientName}}" bindinput="onInput" data-field="patientName" />
          </view>
          <view class="book-divider"></view>
          <view class="book-row">
            <text class="book-label">联系电话</text>
            <input class="book-input" type="number" placeholder="请填写联系电话" value="{{patientPhone}}" bindinput="onInput" data-field="patientPhone" />
          </view>
          <view class="book-divider"></view>
          <view class="book-row book-row-top">
            <text class="book-label">{{serviceMode === 'visit' ? '需求说明' : '补充说明'}}</text>
            <textarea wx:if="{{serviceMode === 'visit'}}" class="book-textarea" placeholder="请填写上门探访需求，可为空" value="{{symptoms}}" bindinput="onInput" data-field="symptoms" auto-height />
            <textarea wx:else class="book-textarea" placeholder="请填写其他说明，可为空" value="{{extraNote}}" bindinput="onInput" data-field="extraNote" auto-height />
          </view>
        </view>
      </view>

      <view style="height:160rpx;"></view>
    </scroll-view>

    <view class="book-bottom">
      <view class="btn-book {{loading ? 'btn-loading' : ''}}" bindtap="submitAppointment">
        <text>{{loading ? '提交中...' : '提交预约'}}</text>
      </view>
    </view>
  </block>
</view>

<global-alarm-overlay />

