.nav-bar {
  background: #3B7EFF;
  display: flex;
  align-items: flex-end;
  height: calc(44px + var(--status-bar-height));
  padding-bottom: 10px;
  position: relative;
}
.nav-title {
  flex: 1;
  text-align: center;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
}
.back-btn {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 80rpx;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon { font-size: 56rpx; color: #fff; }

.page { min-height: 100vh; background: #F5F7FA; }

.scroll { height: calc(100vh - 88px); }

.content-wrap {
  padding: 32rpx 32rpx 60rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.doctor-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: flex-start;
  gap: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.doctor-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #3B7EFF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.avatar-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
}
.doctor-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.doctor-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #111827;
}
.doctor-title {
  font-size: 26rpx;
  color: #3B7EFF;
  font-weight: 600;
}
.doctor-hospital {
  font-size: 26rpx;
  color: #6B7280;
}
.doctor-specialty {
  font-size: 24rpx;
  color: #9CA3AF;
}

.section-block {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.block-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #374151;
  margin-bottom: 24rpx;
}

.slot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.slot-chip {
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  border: 2rpx solid #E5E7EB;
  font-size: 28rpx;
  color: #374151;
  background: #F9FAFB;
}
.slot-active {
  border-color: #3B7EFF;
  background: #EEF4FF;
  color: #3B7EFF;
  font-weight: 700;
}
.slot-disabled {
  opacity: 0.4;
}

.textarea-box {
  border: 1rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 16rpx;
}
.field-textarea {
  width: 100%;
  height: 160rpx;
  font-size: 28rpx;
  color: #111827;
  line-height: 1.6;
}

.submit-btn {
  height: 96rpx;
  background: #3B7EFF;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-top: 16rpx;
}
.btn-disabled { opacity: 0.6; }
