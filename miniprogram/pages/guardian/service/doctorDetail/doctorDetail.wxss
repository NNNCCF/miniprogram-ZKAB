page { background: #EEF2FF; height: 100vh; overflow: hidden; }
.page { height: 100vh; display: flex; flex-direction: column; background: #EEF2FF; }
.nav-bar { flex-shrink: 0; height: 136rpx; position: relative; overflow: hidden; }
.header-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.nav-inner { height: 100%; display: flex; align-items: center; justify-content: space-between; padding: 0 24rpx; position: relative; z-index: 1; }
.nav-back { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; }
.back-arrow { font-size: 52rpx; color: #fff; line-height: 1; }
.nav-title { font-size: 34rpx; font-weight: 700; color: #fff; letter-spacing: 2rpx; }
.body-area { flex: 1; background: #fff; border-radius: 28rpx 28rpx 0 0; margin-top: -32rpx; position: relative; z-index: 2; overflow-y: auto; box-sizing: border-box; }

.content-wrap {
  padding: 32rpx 32rpx 60rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.doctor-card {
  background: #F8FAFF;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: flex-start;
  gap: 28rpx;
}
.doctor-avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: linear-gradient(135deg, #5B7FFF 0%, #3B6EF0 100%);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.doctor-avatar-text { font-size: 48rpx; font-weight: 700; color: #fff; }
.doctor-info { flex: 1; display: flex; flex-direction: column; gap: 10rpx; }
.doctor-name { font-size: 34rpx; font-weight: 800; color: #111827; }
.doctor-title { font-size: 26rpx; color: #3B7EFF; font-weight: 600; }
.doctor-hospital { font-size: 26rpx; color: #6B7280; }

.doctor-meta {
  display: flex;
  background: #F8FAFF;
  border-radius: 20rpx;
  padding: 28rpx 0;
}
.meta-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.meta-num { font-size: 36rpx; font-weight: 800; color: #3B7EFF; }
.meta-label { font-size: 22rpx; color: #9CA3AF; }
.meta-sep { width: 1rpx; background: #E8EEF8; align-self: center; height: 60rpx; }

.section-card { background: #F8FAFF; border-radius: 20rpx; padding: 28rpx 32rpx; }
.section-title { display: block; font-size: 30rpx; font-weight: 700; color: #374151; margin-bottom: 20rpx; }
.section-content { font-size: 26rpx; color: #6B7280; line-height: 1.7; }

.slots-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.slot-item { padding: 16rpx 32rpx; border-radius: 12rpx; border: 2rpx solid #E5E7EB; font-size: 28rpx; color: #374151; background: #fff; display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.slot-active { border-color: #3B7EFF; background: #EEF4FF; color: #3B7EFF; font-weight: 700; }
.slot-disabled { opacity: 0.4; }
.slot-date { font-size: 22rpx; }
.slot-time { font-size: 28rpx; font-weight: 600; }

.form-row { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #F0F4FF; gap: 16rpx; }
.form-row:last-child { border-bottom: none; }
.form-label { font-size: 26rpx; color: #9CA3AF; width: 140rpx; flex-shrink: 0; }
.form-input { flex: 1; font-size: 28rpx; color: #111827; text-align: right; }
.form-textarea { flex: 1; font-size: 28rpx; color: #111827; height: 120rpx; }

.price-bar {
  display: flex; align-items: center; justify-content: space-between;
  background: #F8FAFF; border-radius: 20rpx; padding: 28rpx 32rpx;
}
.price-label { font-size: 24rpx; color: #9CA3AF; display: block; }
.price-val { font-size: 40rpx; font-weight: 800; color: #E63A35; }
.book-btn {
  background: linear-gradient(135deg, #5B7FFF 0%, #3B6EF0 100%);
  border-radius: 44rpx; padding: 20rpx 48rpx;
  font-size: 30rpx; font-weight: 700; color: #fff;
}
