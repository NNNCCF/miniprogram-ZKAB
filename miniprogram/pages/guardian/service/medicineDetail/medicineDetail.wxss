page { background: #3B7EFF; min-height: 100vh; }
.page { display: flex; flex-direction: column; min-height: 100vh; }

.nav-bar { flex-shrink: 0; height: 136rpx; position: relative; overflow: hidden; }
.header-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.nav-inner { height: 100%; display: flex; align-items: center; justify-content: space-between; padding: 0 24rpx; position: relative; z-index: 1; }
.nav-back { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; }
.back-arrow { font-size: 52rpx; color: #fff; line-height: 1; }
.nav-title  { font-size: 34rpx; font-weight: 700; color: #fff; }

.body-area {
  flex: 1; background: #fff;
  border-radius: 32rpx 32rpx 0 0; margin-top: -32rpx;
  position: relative; z-index: 2;
  padding: 0 0 calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.form-card { padding: 0 32rpx; }

/* 表单行 */
.form-row {
  display: flex; align-items: center; justify-content: space-between;
  min-height: 108rpx; padding: 12rpx 0;
}

.label { font-size: 28rpx; color: #1a1a1a; flex-shrink: 0; width: 140rpx; }
.required { color: #E63A35; }

.value-wrap { flex: 1; display: flex; align-items: center; justify-content: flex-end; gap: 8rpx; }
.value { font-size: 28rpx; color: #1a1a1a; text-align: right; flex: 1; }
.time-value { font-size: 32rpx; font-weight: 600; color: #3B7EFF; }
.arrow { font-size: 36rpx; color: #C0C8D8; flex-shrink: 0; }

.input { font-size: 28rpx; color: #1a1a1a; height: 48rpx; }
.right-input { flex: 1; text-align: right; }

.pay-tag { background: #EEF3FF; color: #3B7EFF; font-size: 26rpx; padding: 8rpx 20rpx; border-radius: 8rpx; }

.divider { height: 1rpx; background: #F2F4F8; }

/* 定位行 */
.loc-row { align-items: flex-start; padding-top: 20rpx; padding-bottom: 16rpx; }
.loc-right { flex: 1; display: flex; flex-direction: column; align-items: flex-end; gap: 8rpx; }
.loc-status { display: flex; align-items: center; gap: 8rpx; }
.loc-hint { font-size: 26rpx; color: #9CA3AF; }
.loc-addr-wrap { display: flex; flex-direction: column; align-items: flex-end; gap: 8rpx; }
.loc-addr { font-size: 26rpx; color: #3B7EFF; text-align: right; max-width: 420rpx; line-height: 1.5; }
.loc-fail { font-size: 26rpx; color: #E63A35; }
.reloc-btn { font-size: 22rpx; color: #9CA3AF; text-decoration: underline; }

/* 备注 */
.form-col { padding: 24rpx 0 20rpx; }
.label-top { font-size: 28rpx; color: #1a1a1a; display: block; margin-bottom: 16rpx; }
.textarea { width: 100%; font-size: 28rpx; color: #1a1a1a; min-height: 120rpx; line-height: 1.7; box-sizing: border-box; }
.ph { color: #C0C8D8; }

/* 图片 */
.image-section { display: flex; flex-wrap: wrap; gap: 20rpx; padding: 24rpx 32rpx; }
.img-thumb { width: 160rpx; height: 160rpx; border-radius: 16rpx; overflow: hidden; position: relative; }
.thumb-img { width: 100%; height: 100%; }
.img-remove { position: absolute; top: -8rpx; right: -8rpx; width: 40rpx; height: 40rpx; border-radius: 50%; background: #E63A35; color: #fff; font-size: 28rpx; display: flex; align-items: center; justify-content: center; font-weight: 700; }
.img-add { width: 160rpx; height: 160rpx; border-radius: 16rpx; border: 2rpx dashed #D0D8EF; background: #F8FAFF; display: flex; align-items: center; justify-content: center; }
.add-icon { font-size: 64rpx; color: #C0C8D8; font-weight: 300; line-height: 1; }

/* 底部 */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 20rpx 40rpx calc(24rpx + env(safe-area-inset-bottom)); }
.btn-confirm { background: #4C6EF5; border-radius: 52rpx; height: 100rpx; display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 28rpx rgba(76,110,245,0.40); }
.btn-confirm text { font-size: 32rpx; font-weight: 600; color: #fff; letter-spacing: 4rpx; }
.btn-loading { opacity: 0.7; }
