page { background: #EEF2FF; height: 100vh; overflow: hidden; }
.page { height: 100vh; display: flex; flex-direction: column; background: #EEF2FF; }
.nav-bar { flex-shrink: 0; height: 136rpx; position: relative; overflow: hidden; }
.header-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.nav-inner { height: 100%; display: flex; align-items: center; justify-content: space-between; padding: 0 24rpx; position: relative; z-index: 1; }
.nav-back { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; }
.back-arrow { font-size: 52rpx; color: #fff; line-height: 1; }
.nav-title { font-size: 34rpx; font-weight: 700; color: #fff; letter-spacing: 2rpx; }
.body-area { flex: 1; background: #fff; border-radius: 28rpx 28rpx 0 0; margin-top: -32rpx; position: relative; z-index: 2; overflow-y: auto; padding: 24rpx; box-sizing: border-box; }
.section-title { font-size: 28rpx; font-weight: 600; color: #1A1A2E; margin: 24rpx 0 12rpx; }
.section-title:first-child { margin-top: 0; }
.med-list { background: #F8FAFF; border-radius: 16rpx; overflow: hidden; }
.med-row { display: flex; align-items: center; justify-content: space-between; padding: 24rpx; border-bottom: 1rpx solid #F0F4FF; }
.med-row:last-child { border-bottom: none; }
.med-info { flex: 1; }
.med-name { font-size: 28rpx; color: #1A1A2E; font-weight: 500; display: block; }
.med-spec { font-size: 24rpx; color: #9CA3AF; margin-top: 4rpx; display: block; }
.qty-ctrl { display: flex; align-items: center; gap: 16rpx; }
.qty-btn { width: 52rpx; height: 52rpx; border-radius: 50%; background: #EEF3FB; display: flex; align-items: center; justify-content: center; font-size: 36rpx; color: #3B7EFF; font-weight: 700; }
.qty-num { font-size: 28rpx; color: #1A1A2E; min-width: 32rpx; text-align: center; }
.input-wrap { background: #F8FAFF; border-radius: 16rpx; padding: 24rpx; }
.ipt { font-size: 28rpx; color: #1A1A2E; width: 100%; }
.textarea-wrap { background: #F8FAFF; border-radius: 16rpx; padding: 24rpx; }
.tarea { width: 100%; font-size: 28rpx; color: #1A1A2E; height: 160rpx; }
.ph { color: #9CA3AF; }
.btn-primary { background: linear-gradient(135deg, #3B7EFF, #2060E0); color: #fff; font-size: 32rpx; font-weight: 600; border-radius: 100rpx; height: 96rpx; line-height: 96rpx; text-align: center; margin-top: 40rpx; }
