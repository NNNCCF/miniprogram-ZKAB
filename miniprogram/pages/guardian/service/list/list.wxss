.page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 140rpx;
}

.header {
  padding: 20rpx 32rpx 24rpx;
  background: #fff;
  text-align: center;
}
.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

/* Banner */
.banner {
  margin: 24rpx 24rpx 0;
  background: linear-gradient(135deg, #3B7EFF 0%, #2563EB 100%);
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
}
.banner-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}
.banner-sub {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

/* Section Title */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  padding: 32rpx 32rpx 16rpx;
}

/* Service Grid */
.service-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 24rpx;
}
.service-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.service-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.service-icon { font-size: 48rpx; }
.service-info { flex: 1; }
.service-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}
.service-desc {
  display: block;
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 6rpx;
}
.service-price-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.service-price {
  font-size: 26rpx;
  font-weight: 600;
  color: #3B7EFF;
}
.arrow {
  font-size: 36rpx;
  color: #D1D5DB;
}

/* News List */
.news-list {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.news-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F3F4F6;
  gap: 16rpx;
}
.news-item:last-child { border-bottom: none; }
.news-content { flex: 1; }
.news-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  line-height: 1.5;
}
.news-meta {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}
.news-arrow {
  font-size: 36rpx;
  color: #D1D5DB;
  flex-shrink: 0;
}
