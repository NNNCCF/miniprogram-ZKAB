/* ===== Page Layout ===== */
page {
  background: #EEF2FF;
  height: 100vh;
  overflow: hidden;
}
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #EEF2FF;
}

/* ===== Header ===== */
.header {
  flex-shrink: 0;
  height: 100rpx;
  position: relative;
  overflow: hidden;
}
.header-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
}
.header-inner {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}
.header-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  letter-spacing: 2rpx;
  transform: translateY(-30rpx);
}

/* ===== Body Area ===== */
.body-area {
  flex: 1;
  background: #F5F7FC;
  border-radius: 28rpx 28rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  overflow-y: auto;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== Main Cards ===== */
.main-cards {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 24rpx 0;
  align-items: stretch;
}

.card-doctor {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(43, 107, 224, 0.10);
  position: relative;
  display: flex;
  flex-direction: column;
}
.bound-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: #3B7EFF;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  z-index: 1;
}
.card-doctor-img { width: 100%; display: block; }
.card-doctor-info {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 48rpx 20rpx 20rpx;
  background: linear-gradient(to top, rgba(10, 18, 40, 0.75) 0%, transparent 100%);
}
.card-doctor-role {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 6rpx;
}
.card-doctor-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}
.card-doctor-org {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
  margin-top: 4rpx;
}
.rating-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 8rpx;
}
.rating-star {
  font-size: 20rpx;
  color: #FBBF24;
  letter-spacing: 1rpx;
}
.rating-num {
  font-size: 22rpx;
  color: #FBBF24;
  font-weight: 600;
}

.cards-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.card-small {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(43, 107, 224, 0.10);
  position: relative;
}
.card-small-img { width: 100%; display: block; }
.card-small-label {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 32rpx 16rpx 16rpx;
  background: linear-gradient(to top, rgba(10, 18, 40, 0.72) 0%, transparent 100%);
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
}

/* ===== Section Header ===== */
.section-header {
  padding: 28rpx 24rpx 16rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0F1C38;
}

/* ===== Quick Services ===== */
.quick-row {
  display: flex;
  justify-content: space-around;
  padding: 0 16rpx 4rpx;
}
.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.quick-circle {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(43, 107, 224, 0.12);
}
.quick-icon { width: 100%; height: 100%; }
.quick-label {
  font-size: 24rpx;
  color: #4A587A;
}

/* ===== News List ===== */
.news-list {
  background: #fff;
  margin: 0 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(43, 107, 224, 0.06);
}
.news-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #F5F7FC;
  gap: 16rpx;
}
.news-item:last-child { border-bottom: none; }
.news-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #3B7EFF;
  flex-shrink: 0;
}
.news-body { flex: 1; }
.news-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #0F1C38;
  line-height: 1.5;
}
.news-meta {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 6rpx;
}
.news-arrow {
  font-size: 36rpx;
  color: #D1D5DB;
  flex-shrink: 0;
}
