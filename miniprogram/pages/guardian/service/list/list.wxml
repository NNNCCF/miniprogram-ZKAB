<view class="page">
  <view class="header" style="padding-top:{{statusH}}px;">
    <image class="header-bg" src="/images/nav_top_bg.png" mode="aspectFill" />
    <view class="header-inner">
      <text class="header-title">预约服务</text>
    </view>
  </view>

  <scroll-view class="body-area" scroll-y>
    <!-- 三大服务卡片 -->
    <view class="main-cards">
      <view class="card-doctor" bindtap="goDoctor">
        <view class="bound-badge">已绑定</view>
        <image class="card-doctor-img" src="/images/家庭医生卡.png" mode="widthFix" />
        <view class="card-doctor-info">
          <text class="card-doctor-role">家庭医生</text>
          <text class="card-doctor-name">王医生</text>
          <text class="card-doctor-org">市第一人民医院</text>
          <view class="rating-row">
            <text class="rating-star">★★★★★</text>
            <text class="rating-num">4.9</text>
          </view>
        </view>
      </view>
      <view class="cards-right">
        <view class="card-small" bindtap="goCommunity">
          <image class="card-small-img" src="/images/小区物业.png" mode="widthFix" />
          <text class="card-small-label">小区物业</text>
        </view>
        <view class="card-small" bindtap="goHospital">
          <image class="card-small-img" src="/images/医疗机构卡.png" mode="widthFix" />
          <text class="card-small-label">医疗机构</text>
        </view>
      </view>
    </view>

    <!-- 快捷服务 -->
    <view class="section-header">
      <text class="section-title">快捷服务</text>
    </view>
    <view class="quick-row">
      <view class="quick-item" bindtap="goQuick" data-type="medicine">
        <view class="quick-circle">
          <image class="quick-icon" src="/images/送药.png" mode="aspectFill" />
        </view>
        <text class="quick-label">送药</text>
      </view>
      <view class="quick-item" bindtap="goQuick" data-type="visit">
        <view class="quick-circle">
          <image class="quick-icon" src="/images/家访探视.png" mode="aspectFill" />
        </view>
        <text class="quick-label">家访探视</text>
      </view>
      <view class="quick-item" bindtap="goQuick" data-type="checkup">
        <view class="quick-circle">
          <image class="quick-icon" src="/images/预约体检.png" mode="aspectFill" />
        </view>
        <text class="quick-label">预约体检</text>
      </view>
      <view class="quick-item" bindtap="goQuick" data-type="nursing">
        <view class="quick-circle">
          <image class="quick-icon" src="/images/护理.png" mode="aspectFill" />
        </view>
        <text class="quick-label">护理</text>
      </view>
    </view>

    <!-- 健康动态 -->
    <view class="section-header">
      <text class="section-title">健康动态</text>
    </view>
    <view class="news-list">
      <view class="news-item" wx:for="{{news}}" wx:key="id" bindtap="goNews" data-id="{{item.id}}">
        <view class="news-dot"></view>
        <view class="news-body">
          <text class="news-title">{{item.title}}</text>
          <text class="news-meta">{{item.date}} · {{item.author}}</text>
        </view>
        <text class="news-arrow">›</text>
      </view>
    </view>
  </scroll-view>

  <guardian-tabbar active="appt"></guardian-tabbar>
</view>
