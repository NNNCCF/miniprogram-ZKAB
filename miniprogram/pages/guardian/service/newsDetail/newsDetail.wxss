.nav-bar { background:#3B7EFF; display:flex; align-items:flex-end; padding-bottom:10px; position:relative; }
.nav-title { flex:1; text-align:center; color:#fff; font-size:34rpx; font-weight:600; }
.back-btn { position:absolute; left:0; bottom:0; width:80rpx; height:44px; display:flex; align-items:center; justify-content:center; }
.back-icon { font-size:56rpx; color:#fff; }
.body { padding:32rpx; background:#fff; min-height:100vh; }
.article-title { font-size:36rpx; font-weight:700; color:#1A1A2E; line-height:1.5; display:block; margin-bottom:20rpx; }
.meta-row { display:flex; gap:24rpx; margin-bottom:24rpx; }
.meta-text { font-size:24rpx; color:#9CA3AF; }
.divider { height:1rpx; background:#F0F1F5; margin-bottom:32rpx; }
.content { font-size:28rpx; color:#374151; line-height:1.8; display:block; }
.loading { display:flex; justify-content:center; padding:80rpx; color:#9CA3AF; font-size:28rpx; }
