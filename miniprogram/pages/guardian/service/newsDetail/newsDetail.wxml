<view class="page">
  <view class="nav-bar" style="padding-top:{{statusH}}px;">
    <image class="header-bg" src="/images/nav_top_bg.png" mode="aspectFill" />
    <view class="nav-inner">
      <view class="nav-back" bindtap="goBack"><text class="back-arrow">←</text></view>
      <text class="nav-title">动态详情</text>
      <view style="width:60rpx;"></view>
    </view>
  </view>
  <scroll-view scroll-y class="body-area" wx:if="{{article.title}}">
    <text class="article-title">{{article.title}}</text>
    <view class="meta-row">
      <text class="meta-text">{{article.author}}</text>
      <text class="meta-text">{{article.date}}</text>
    </view>
    <view class="divider"></view>
    <text class="article-content">{{article.content}}</text>
  </scroll-view>
  <view class="loading" wx:if="{{loading}}"><text>加载中...</text></view>
</view>
