<view class="page">
  <view style="height:{{statusH}}px;background:#fff;"></view>
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack"><text class="back-arrow">‹</text></view>
    <text class="nav-title">添加家庭成员</text>
  </view>

  <scroll-view class="form-scroll" scroll-y>
    <view class="form-content">

      <!-- Name -->
      <view class="form-group">
        <text class="form-label">姓名 <text class="required">*</text></text>
        <view class="input-wrap">
          <input class="form-input" placeholder="请输入姓名" value="{{form.name}}" bindinput="onInput" data-field="name"/>
        </view>
      </view>

      <!-- Age -->
      <view class="form-group">
        <text class="form-label">年龄 <text class="required">*</text></text>
        <view class="input-wrap">
          <input class="form-input" type="number" placeholder="请输入年龄" value="{{form.age}}" bindinput="onInput" data-field="age"/>
        </view>
      </view>

      <!-- Gender -->
      <view class="form-group">
        <text class="form-label">性别 <text class="required">*</text></text>
        <view class="radio-group">
          <view class="radio-item {{form.gender === 'male' ? 'radio-active' : ''}}" bindtap="setGender" data-val="male">
            <text>男</text>
          </view>
          <view class="radio-item {{form.gender === 'female' ? 'radio-active' : ''}}" bindtap="setGender" data-val="female">
            <text>女</text>
          </view>
        </view>
      </view>

      <!-- Relationship -->
      <view class="form-group">
        <text class="form-label">与我的关系 <text class="required">*</text></text>
        <view class="input-wrap">
          <picker range="{{relationships}}" value="{{relIndex}}" bindchange="onRelChange">
            <view class="picker-display">
              <text class="{{form.relationship ? 'picker-text' : 'picker-placeholder'}}">{{form.relationship || '请选择关系'}}</text>
              <text class="picker-arrow">›</text>
            </view>
          </picker>
        </view>
      </view>

      <!-- Medical History -->
      <view class="form-group">
        <text class="form-label">既往病史</text>
        <view class="textarea-wrap">
          <textarea
            class="form-textarea"
            placeholder="请输入既往病史（选填）"
            value="{{form.medicalHistory}}"
            bindinput="onInput"
            data-field="medicalHistory"
            maxlength="200"
          />
        </view>
        <text class="char-count">{{form.medicalHistory.length || 0}}/200</text>
      </view>

      <!-- Phone -->
      <view class="form-group">
        <text class="form-label">联系电话</text>
        <view class="input-wrap">
          <input class="form-input" type="number" placeholder="请输入联系电话（选填）" value="{{form.phone}}" bindinput="onInput" data-field="phone"/>
        </view>
      </view>

      <!-- Submit -->
      <view class="submit-btn" bindtap="onSubmit">
        <text class="submit-text">{{loading ? '提交中...' : '确认添加'}}</text>
      </view>
    </view>
  </scroll-view>
</view>
