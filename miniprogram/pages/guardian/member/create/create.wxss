page { background: #EEF2FF; height: 100vh; overflow: hidden; }
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #EEF2FF;
}

.nav-bar {
  position: relative;
  overflow: hidden;
  height: 136rpx;
  flex-shrink: 0;
}
.header-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.nav-inner { height: 100%; display: flex; align-items: center; justify-content: space-between; padding: 0 24rpx; position: relative; z-index: 1; }
.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-arrow {
  font-size: 52rpx;
  color: #fff;
  line-height: 1;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
}

.body-area {
  flex: 1;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  overflow-y: auto;
  box-sizing: border-box;
}
.form-content {
  padding: 24rpx 24rpx 60rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.form-group {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
}
.form-label {
  display: block;
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
}
.required { color: #EF4444; }

.input-wrap {
  border-bottom: 1rpx solid #F3F4F6;
}
.form-input {
  width: 100%;
  height: 72rpx;
  font-size: 30rpx;
  color: #111827;
}

.radio-group {
  display: flex;
  gap: 24rpx;
}
.radio-item {
  flex: 1;
  height: 72rpx;
  border-radius: 12rpx;
  border: 2rpx solid #E5E7EB;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #6B7280;
}
.radio-active {
  border-color: #3B7EFF;
  background: #EEF3FF;
  color: #3B7EFF;
  font-weight: 700;
}

.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
}
.picker-text {
  font-size: 30rpx;
  color: #111827;
}
.picker-placeholder {
  font-size: 30rpx;
  color: #9CA3AF;
}
.picker-arrow {
  font-size: 36rpx;
  color: #D1D5DB;
}

.textarea-wrap {
  border: 1rpx solid #F3F4F6;
  border-radius: 12rpx;
  padding: 16rpx;
}
.form-textarea {
  width: 100%;
  height: 160rpx;
  font-size: 28rpx;
  color: #111827;
  line-height: 1.6;
}
.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

.submit-btn {
  margin-top: 24rpx;
  height: 96rpx;
  background: #3B7EFF;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.submit-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

/* ===== 顶部 nav-bar（返回款）===== */
.nav-bar {
  position: relative;
  overflow: hidden;
  height: 88rpx;
  flex-shrink: 0;
}
.header-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
}
.nav-inner {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  position: relative;
  z-index: 1;
}
.nav-back {
  width: 60rpx; height: 60rpx;
  display: flex; align-items: center; justify-content: center;
}
.back-arrow {
  font-size: 52rpx;
  color: #fff;
  line-height: 1;
}
.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

