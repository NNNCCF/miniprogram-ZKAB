<view class="page">
  <!-- 导航栏 -->
  <view class="nav-bar" style="padding-top:{{statusH}}px;">
    <image class="header-bg" src="/images/nav_top_bg.png" mode="aspectFill" />
    <view class="nav-inner">
      <view class="nav-back" bindtap="goBack"><text class="back-arrow">←</text></view>
      <text class="nav-title">设备绑定</text>
      <view style="width:60rpx;"></view>
    </view>
  </view>

  <view class="body-area">

    <!-- 成功状态 -->
    <view wx:if="{{isSuccess}}" class="result-wrap">
      <view class="status-circle success-circle">
        <text class="status-icon">✓</text>
      </view>
      <text class="result-title">设备绑定成功</text>
      <text class="result-link" bindtap="onCreateMember">建立人员初始档案，并识别绑定人员</text>
      <view class="primary-btn" bindtap="onCreateMember">
        <text class="btn-plus">+</text>
        <text class="btn-text">创建成员</text>
      </view>
    </view>

    <!-- 失败状态 -->
    <view wx:else class="result-wrap">
      <view class="status-circle fail-circle">
        <text class="status-icon">✕</text>
      </view>
      <text class="result-title">设备绑定失败</text>
      <text class="result-error">{{errorMsg || '绑定失败，请检查设备号后重试！'}}</text>
      <view class="primary-btn" bindtap="goRetry">
        <text class="btn-text">返回重新绑定</text>
      </view>
    </view>

  </view>
</view>
