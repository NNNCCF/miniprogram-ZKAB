<view class="page">

  <!-- 导航栏 -->
  <view class="nav-bar" style="padding-top:{{statusH}}px;">
    <image class="header-bg" src="/images/nav_top_bg.png" mode="aspectFill" />
    <view class="nav-inner">
      <view class="nav-back" bindtap="goBack"><text class="back-arrow">←</text></view>
      <text class="nav-title">设备绑定</text>
      <view style="width:60rpx;"></view>
    </view>
  </view>

  <!-- 白色内容区 -->
  <scroll-view class="body-area" scroll-y show-scrollbar="{{false}}" enhanced="{{true}}">

    <!-- 链接图标 -->
    <view class="icon-wrap">
      <image class="link-icon-img" src="/images/icon_device_link.png" mode="aspectFit" />
    </view>

    <!-- 表单字段 -->
    <view class="form">

      <view class="field-row">
        <text class="field-label">设备号 <text class="required">*</text></text>
        <input class="field-input" placeholder="请填写设备号" placeholder-class="field-ph"
          value="{{deviceCode}}" bindinput="onDeviceCodeInput" maxlength="40" />
      </view>
      <view class="field-divider"></view>

      <view class="field-row">
        <text class="field-label">住所位置</text>
        <view wx:if="{{locating}}" class="location-mid">
          <text class="field-ph">定位中...</text>
        </view>
        <text wx:elif="{{location}}" class="location-text field-val-text">
          <text class="pin">📍</text>{{locationText}}
        </text>
        <text wx:elif="{{locationFailed}}" class="location-text" style="color:#bbb;font-size:24rpx;">定位失败（可选）</text>
        <text wx:else class="location-text field-ph">点击定位（可选）</text>
        <view class="relocate-btn" catchtap="getLocation">
          <text class="relocate-text">{{locating ? '' : (location ? '重定位' : '定位')}}</text>
        </view>
      </view>
      <view class="field-divider"></view>

      <view class="field-row">
        <text class="field-label">门牌号 <text class="required">*</text></text>
        <input class="field-input" placeholder="详细地址，例1号楼1单元101室" placeholder-class="field-ph"
          value="{{address}}" bindinput="onAddressInput" />
      </view>
      <view class="field-divider"></view>

      <view class="field-row">
        <text class="field-label">居家位置 <text class="required">*</text></text>
        <input class="field-input" placeholder="例客厅、卧室" placeholder-class="field-ph"
          value="{{roomLocation}}" bindinput="onRoomInput" />
      </view>
      <view class="field-divider"></view>

    </view>

    <!-- 确认按钮 -->
    <view class="confirm-btn {{canSubmit ? '' : 'btn-disabled'}}" bindtap="onConfirm">
      <text class="confirm-text">{{loading ? '绑定中...' : '确认绑定'}}</text>
    </view>

  </scroll-view>
</view>
