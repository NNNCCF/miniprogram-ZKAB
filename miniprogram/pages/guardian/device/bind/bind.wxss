page {
  background: #EEF2FF;
  height: 100vh;
  overflow: hidden;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #EEF2FF;
}

/* ===== 导航栏 ===== */
.nav-bar {
  position: relative;
  flex-shrink: 0;
  height: 50px;
}
.header-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
}
.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  position: relative;
  z-index: 1;
  margin-top: -15px;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-arrow {
  font-size: 52rpx;
  color: #fff;
  line-height: 1;
}
.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

/* 右侧胶囊按钮 */
.nav-right-capsule {
  display: flex;
  align-items: center;
  height: 56rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.15);
  overflow: hidden;
}
.nav-capsule-btn {
  width: 64rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-capsule-dot {
  font-size: 26rpx;
  color: #fff;
  letter-spacing: -2rpx;
  line-height: 1;
}
.nav-capsule-scan {
  font-size: 30rpx;
  color: #fff;
  line-height: 1;
}
.nav-capsule-divider {
  width: 1rpx;
  height: 32rpx;
  background: rgba(255, 255, 255, 0.5);
}

/* ===== 白色内容区 ===== */
.body-area {
  flex: 1;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  overflow-y: auto;
  padding: 56rpx 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

/* ===== 链接图标 ===== */
.icon-wrap {
  margin-top: 40rpx;
  margin-bottom: 60rpx;
  display: flex;
  justify-content: center;
}
.link-icon-img {
  width: 220rpx;
  height: 220rpx;
  animation: breathe 2.4s ease-in-out infinite;
}

@keyframes breathe {
  0%   { transform: scale(1);    }
  50%  { transform: scale(1.12); }
  100% { transform: scale(1);    }
}

/* ===== 表单 ===== */
.form {
  width: 100%;
  margin-bottom: 60rpx;
}

.field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64px;
}
.field-label {
  font-size: 28rpx;
  color: #111827;
  flex-shrink: 0;
  min-width: 140rpx;
}
.required {
  color: #E63A35;
  font-size: 28rpx;
}
.field-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #111827;
  height: 60rpx;
}
.field-ph {
  color: #B0B8CC;
  font-size: 28rpx;
}
/* 住所位置：中间文字 + 右侧按钮 */
.location-text {
  flex: 1;
  font-size: 26rpx;
  text-align: right;
  margin-right: 16rpx;
  color: #E63A35;
  overflow: hidden;
}
.location-mid {
  flex: 1;
  text-align: right;
  margin-right: 16rpx;
}
.field-val-text {
  font-size: 26rpx;
  color: #E63A35;
}
.pin { font-size: 24rpx; }
.relocate-btn {
  flex-shrink: 0;
  padding: 6rpx 20rpx;
  border: 1rpx solid #3B7EFF;
  border-radius: 24rpx;
}
.relocate-text {
  font-size: 22rpx;
  color: #3B7EFF;
}
.field-divider {
  height: 1rpx;
  background: #F0F2F8;
}

/* ===== 确认按钮 ===== */
.confirm-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #5B7FFF 0%, #3B6EF0 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(59, 110, 240, 0.35);
}
.btn-disabled {
  background: #B0C4FF;
  box-shadow: none;
}
.confirm-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 4rpx;
}
