page {
  background: #EEF2FF;
  height: 100vh;
  overflow: hidden;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #EEF2FF;
}

/* ===== 导航栏 ===== */
.nav-bar {
  position: relative;
  overflow: hidden;
  height: 136rpx;
  flex-shrink: 0;
}
.header-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
}
.nav-inner {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  position: relative;
  z-index: 1;
}
/* 以下为原有样式兼容占位 */
.nav-bar-old {
  flex-shrink: 0;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 52rpx;
  color: #fff;
  line-height: 1;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

/* ===== 白色内容区 ===== */
.body-area {
  flex: 1;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  overflow-y: auto;
  padding: 56rpx 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

/* ===== 链接图标 ===== */
.icon-wrap {
  margin-bottom: 60rpx;
}

.icon-outer {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(91, 127, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-inner {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5B7FFF 0%, #3B6EF0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.chain-icon {
  font-size: 56rpx;
  filter: grayscale(1) brightness(10);
}

/* ===== 表单 ===== */
.form {
  width: 100%;
  margin-bottom: 60rpx;
}

.field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0;
  min-height: 96rpx;
}

.field-label {
  font-size: 28rpx;
  color: #111827;
  flex-shrink: 0;
  min-width: 140rpx;
}

.required {
  color: #E63A35;
  font-size: 28rpx;
}

.field-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #111827;
  height: 60rpx;
}

.field-ph {
  color: #B0B8CC;
  font-size: 28rpx;
}

.location-val {
  flex: 1;
  text-align: right;
}

.field-val-text {
  font-size: 28rpx;
  color: #E63A35;
}

.pin {
  font-size: 24rpx;
}

.field-divider {
  height: 1rpx;
  background: #F0F2F8;
}

/* ===== 确认按钮 ===== */
.confirm-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #5B7FFF 0%, #3B6EF0 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(59, 110, 240, 0.35);
}

.btn-disabled {
  background: #B0C4FF;
  box-shadow: none;
}

.confirm-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 4rpx;
}
