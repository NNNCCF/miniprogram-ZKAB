/* ===== Page Layout ===== */
page {
  background: #1A2A4A;
  height: 100vh;
  overflow: hidden;
}
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #1A2A4A;
}

/* ===== Header ===== */
.header {
  flex-shrink: 0;
  height: 100rpx;
  position: relative;
  overflow: hidden;
}
.header-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
}
.header-inner {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}
.header-title {
  font-size: 43rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
  transform: translateY(-35rpx);
}

/* ===== Body Area ===== */
.body-area {
  flex: 1;
  background: #1A2A4A;
  border-radius: 28rpx 28rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== Health Section ===== */
.health-section {
  flex: 1;
  padding: 40rpx 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.health-row {
  display: flex;
  gap: 16rpx;
}
.health-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.health-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
}
.health-val {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}
.health-unit {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  min-height: 28rpx;
}
.health-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
}
.health-hint {
  display: flex;
  justify-content: center;
}
.health-hint-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
  letter-spacing: 1rpx;
}

/* ===== Action Section ===== */
.action-section {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-call {
  background: #fff;
  border-radius: 28rpx;
  padding: 40rpx 36rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.25);
}
.action-call:active { background: #F5F8FF; }

.call-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #E8F3FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.call-icon-img {
  width: 44rpx;
  height: 44rpx;
}
.call-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #0F1C38;
  letter-spacing: 1rpx;
}

.action-cancel {
  background: rgba(255, 255, 255, 0.12);
  border-radius: 28rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.action-cancel:active { background: rgba(255, 255, 255, 0.18); }
.cancel-text {
  font-size: 34rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.65);
}
