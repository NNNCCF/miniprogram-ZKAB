<view class="page">
  <view class="header" style="padding-top:{{statusH}}px;">
    <image class="header-bg" src="/images/nav_top_bg.png" mode="aspectFill" />
    <view class="header-inner">
      <text class="header-title">一键呼救</text>
    </view>
  </view>

  <view class="body-area">
    <!-- Health data context (dimmed background panels) -->
    <view class="health-section">
      <view class="health-row">
        <view class="health-card">
          <image class="health-icon" src="/images/icon_heartwave.png" mode="aspectFit" />
          <text class="health-val">78</text>
          <text class="health-unit">bpm</text>
          <text class="health-label">心率</text>
        </view>
        <view class="health-card">
          <image class="health-icon" src="/images/icon_walk.png" mode="aspectFit" />
          <text class="health-val">3,241</text>
          <text class="health-unit">步</text>
          <text class="health-label">今日步数</text>
        </view>
        <view class="health-card">
          <image class="health-icon" src="/images/icon_fall.png" mode="aspectFit" />
          <text class="health-val">安全</text>
          <text class="health-unit"> </text>
          <text class="health-label">跌倒检测</text>
        </view>
      </view>
      <view class="health-hint">
        <text class="health-hint-text">检测到异常情况？立即联系服务中心</text>
      </view>
    </view>

    <!-- Action cards -->
    <view class="action-section">
      <view class="action-call" bindtap="onCall">
        <view class="call-icon-wrap">
          <image class="call-icon-img" src="/images/客服电话.png" mode="aspectFit" />
        </view>
        <text class="call-text">呼叫 0351-1234567</text>
      </view>
      <view class="action-cancel" bindtap="onCancel">
        <text class="cancel-text">取消</text>
      </view>
    </view>
  </view>

  <guardian-tabbar active="emergency"></guardian-tabbar>
</view>
