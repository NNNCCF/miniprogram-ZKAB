page { background: #EEF2FF; height: 100vh; overflow: hidden; }
.page { height: 100vh; display: flex; flex-direction: column; background: #EEF2FF; }
.nav-bar { flex-shrink: 0; height: 136rpx; position: relative; overflow: hidden; }
.header-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.nav-inner { height: 100%; display: flex; align-items: center; justify-content: space-between; padding: 0 24rpx; position: relative; z-index: 1; }
.nav-back { width: 60rpx; height: 60rpx; display: flex; align-items: center; justify-content: center; }
.back-arrow { font-size: 52rpx; color: #fff; line-height: 1; }
.nav-title { font-size: 34rpx; font-weight: 700; color: #fff; letter-spacing: 2rpx; }
.body-area { flex: 1; background: #fff; border-radius: 28rpx 28rpx 0 0; margin-top: -32rpx; position: relative; z-index: 2; overflow-y: auto; padding: 32rpx 24rpx; box-sizing: border-box; }
.card { background: #F8FAFF; border-radius: 16rpx; overflow: hidden; }
.row { display: flex; justify-content: space-between; align-items: center; padding: 28rpx; border-bottom: 1rpx solid #F0F4FF; }
.row:last-child { border-bottom: none; }
.row-label { font-size: 28rpx; color: #1A1A2E; }
.row-val { font-size: 26rpx; color: #9CA3AF; }
.row-arrow { font-size: 36rpx; color: #9CA3AF; }
.logout-btn { margin-top: 60rpx; background: #F8FAFF; border-radius: 16rpx; height: 96rpx; line-height: 96rpx; text-align: center; font-size: 32rpx; color: #FF4B4B; font-weight: 600; }
