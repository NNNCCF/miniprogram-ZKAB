<view class="nav-bar" style="padding-top:{{statusH}}px;">
  <view class="back-btn" bindtap="goBack"><text class="back-icon">‹</text></view>
  <text class="nav-title">系统设置</text>
</view>
<view class="body">
  <view class="card">
    <view class="row">
      <text class="row-label">报警推送通知</text>
      <switch checked="{{pushOn}}" bindchange="onPush" color="#3B7EFF" />
    </view>
  </view>
  <view class="card" style="margin-top:24rpx;">
    <view class="row" bindtap="clearCache">
      <text class="row-label">清除缓存</text>
      <text class="row-arrow">›</text>
    </view>
    <view class="row" bindtap="showAbout">
      <text class="row-label">关于我们</text>
      <text class="row-val">v1.0.0</text>
    </view>
  </view>
  <view class="logout-btn" bindtap="logout">退出登录</view>
</view>
