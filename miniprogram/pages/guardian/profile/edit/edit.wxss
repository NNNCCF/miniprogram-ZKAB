page {
  background: #3B7EFF;
  min-height: 100vh;
}

.page {
  min-height: 100vh;
}

.nav-bar {
  flex-shrink: 0;
  height: 136rpx;
  position: relative;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.nav-inner {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  position: relative;
  z-index: 1;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 52rpx;
  color: #fff;
  line-height: 1;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.body-area {
  background: #F5F6FA;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  min-height: calc(100vh - 140rpx);
  padding: 32rpx 32rpx calc(60rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 40rpx;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 0 36rpx;
  height: 96rpx;
  gap: 24rpx;
}

.form-label {
  flex-shrink: 0;
  width: 160rpx;
  font-size: 28rpx;
  color: #555;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  text-align: right;
}

.divider {
  height: 1rpx;
  background: #F5F5F5;
  margin: 0 36rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: #3B7EFF;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(59, 126, 255, 0.35);
}