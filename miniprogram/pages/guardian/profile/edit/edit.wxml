<view class="page">
  <view class="nav-bar" style="padding-top:{{statusH}}px;">
    <image class="header-bg" src="/images/nav_top_bg.png" mode="aspectFill" />
    <view class="nav-inner">
      <view class="nav-back" bindtap="goBack"><text class="back-arrow">←</text></view>
      <text class="nav-title">编辑资料</text>
      <view style="width:60rpx;"></view>
    </view>
  </view>

  <view class="body-area">
    <view class="card">
      <view class="form-row">
        <text class="form-label">姓名</text>
        <input class="form-input" placeholder="请输入姓名" value="{{form.name}}" bindinput="onInput" data-field="name" />
      </view>
      <view class="divider"></view>
      <view class="form-row">
        <text class="form-label">手机号</text>
        <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onInput" data-field="phone" />
      </view>
    </view>

    <button class="save-btn" bindtap="onSave" loading="{{saving}}">保存</button>
  </view>
</view>