/* ===== Page Layout ===== */
page {
  background: #EEF2FF;
  height: 100vh;
  overflow: hidden;
}
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #EEF2FF;
}

/* ===== Header ===== */
.header {
  flex-shrink: 0;
  height: 100rpx;
  position: relative;
  overflow: hidden;
}
.header-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
}
.header-inner {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}
.header-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  letter-spacing: 2rpx;
  transform: translateY(-30rpx);
}

/* ===== Body Area ===== */
.body-area {
  flex: 1;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  overflow-y: auto;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* Profile Header */
.profile-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 36rpx 32rpx 32rpx;
}
.avatar-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5B7FFF 0%, #3B6EF0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(59, 110, 240, 0.35);
}
.avatar-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}
.user-info { flex: 1; }
.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}
.user-phone {
  display: block;
  font-size: 26rpx;
  color: #6B7280;
  margin-top: 6rpx;
}
.edit-btn {
  background: #EEF3FF;
  border-radius: 30rpx;
  padding: 10rpx 24rpx;
}
.edit-text {
  font-size: 26rpx;
  color: #3B7EFF;
  font-weight: 500;
}

/* Stats Row */
.stats-row {
  display: flex;
  background: #F8FAFF;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 28rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(59, 110, 240, 0.08);
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.stat-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #3B7EFF;
}
.stat-label {
  font-size: 24rpx;
  color: #9CA3AF;
}
.stat-sep {
  width: 1rpx;
  height: 60rpx;
  background: #E8EEF8;
  align-self: center;
}

/* Menu */
.menu-section {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.menu-group {
  background: #F8FAFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F0F4FF;
  gap: 20rpx;
  background: #fff;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; }
.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #111827;
}
.menu-arrow {
  font-size: 36rpx;
  color: #D1D5DB;
}

/* Logout */
.logout-btn {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
.logout-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #EF4444;
}
