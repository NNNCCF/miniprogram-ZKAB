<view class="page">
  <view class="header" style="padding-top:{{statusH}}px;">
    <image class="header-bg" src="/images/nav_top_bg.png" mode="aspectFill" />
    <view class="header-inner">
      <text class="header-title">我的</text>
    </view>
  </view>

  <scroll-view class="body-area" scroll-y>
    <!-- Profile Header -->
    <view class="profile-header">
      <view class="avatar-wrap">
        <text class="avatar-text">{{userInfo.name ? userInfo.name[0] : '我'}}</text>
      </view>
      <view class="user-info">
        <text class="user-name">{{userInfo.name || '守护者'}}</text>
        <text class="user-phone">{{userInfo.phone || ''}}</text>
      </view>
      <view class="edit-btn" bindtap="goEdit">
        <text class="edit-text">编辑</text>
      </view>
    </view>

    <!-- Stats Row -->
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-num">{{stats.memberCount || 0}}</text>
        <text class="stat-label">守护成员</text>
      </view>
      <view class="stat-sep"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.alarmCount || 0}}</text>
        <text class="stat-label">今日预警</text>
      </view>
      <view class="stat-sep"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.serviceCount || 0}}</text>
        <text class="stat-label">服务订单</text>
      </view>
    </view>

    <!-- Menu List -->
    <view class="menu-section">
      <view class="menu-group">
        <view class="menu-item" bindtap="goSwitchMember">
          <text class="menu-icon">👥</text>
          <text class="menu-label">切换成员</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goAlarmSettings">
          <text class="menu-icon">🔔</text>
          <text class="menu-label">报警设置</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>

      <view class="menu-group">
        <view class="menu-item" bindtap="goServiceCenter">
          <text class="menu-icon">🎧</text>
          <text class="menu-label">服务中心</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goFeedback">
          <text class="menu-icon">💬</text>
          <text class="menu-label">意见反馈</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="goSettings">
          <text class="menu-icon">⚙️</text>
          <text class="menu-label">系统设置</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>

      <view class="logout-btn" bindtap="logout">
        <text class="logout-text">退出登录</text>
      </view>
    </view>
  </scroll-view>

  <guardian-tabbar active="profile"></guardian-tabbar>
</view>
