<view class="nav-bar" style="padding-top:{{statusH}}px;">
  <view class="back-btn" bindtap="goBack"><text class="back-icon">‹</text></view>
  <text class="nav-title">报警设置</text>
</view>
<view class="body">
  <view class="card">
    <view wx:for="{{settings}}" wx:key="key" class="setting-row">
      <view class="setting-left">
        <text class="setting-label">{{item.label}}</text>
        <text class="setting-desc">{{item.desc}}</text>
      </view>
      <switch checked="{{item.value}}" bindchange="onChange" data-key="{{item.key}}" color="#3B7EFF" />
    </view>
  </view>
</view>
