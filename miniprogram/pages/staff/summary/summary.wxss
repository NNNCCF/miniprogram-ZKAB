page {
  background: linear-gradient(165deg, #1B3A70 0%, #3B7EFF 100%);
  min-height: 100vh;
}

.page-body {
  background: #F2F5FC;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  min-height: calc(100vh - 180rpx);
  padding: 32rpx 28rpx calc(60rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== Section Title ===== */
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0F1C38;
  letter-spacing: 1rpx;
  margin-bottom: 20rpx;
  display: block;
}

.section-title-mt {
  margin-top: 40rpx;
}

/* ===== Stats Grid 2×2 ===== */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.stat-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 16rpx rgba(43, 107, 224, 0.07);
}

.stat-card-blue {
  background: linear-gradient(135deg, #2352C8 0%, #3B7EFF 100%);
  box-shadow: 0 8rpx 28rpx rgba(59, 126, 255, 0.32);
}

.stat-card-orange {
  background: linear-gradient(135deg, #D45E18 0%, #F08030 100%);
  box-shadow: 0 8rpx 28rpx rgba(212, 94, 24, 0.28);
}

.stat-number {
  font-size: 52rpx;
  font-weight: 800;
  color: #3B7EFF;
  line-height: 1.1;
  letter-spacing: -1rpx;
}

.stat-number-white {
  color: #fff;
}

.stat-label {
  font-size: 22rpx;
  color: #9CA3B4;
  letter-spacing: 0.5rpx;
}

.stat-label-white {
  color: rgba(255, 255, 255, 0.80);
}

/* ===== Bar Chart ===== */
.chart-wrap {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  box-shadow: 0 2rpx 16rpx rgba(43, 107, 224, 0.07);
}

.chart-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.chart-label {
  font-size: 24rpx;
  color: #4A587A;
  width: 128rpx;
  flex-shrink: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bar-container {
  flex: 1;
  height: 14rpx;
  background: #EBF0FA;
  border-radius: 7rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #3B7EFF 0%, #6FA0FF 100%);
  border-radius: 7rpx;
  min-width: 4rpx;
}

.chart-count {
  font-size: 26rpx;
  font-weight: 700;
  color: #3B7EFF;
  width: 52rpx;
  text-align: right;
  flex-shrink: 0;
}

/* ===== Empty ===== */
.empty-chart {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 16rpx rgba(43, 107, 224, 0.07);
}

.hint-text {
  font-size: 26rpx;
  color: #C0C8D8;
}
