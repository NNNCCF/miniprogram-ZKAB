<staff-navbar title="数据汇总" show-back="{{true}}" />

<view class="page-body">

  <!-- Stats Grid 2×2 -->
  <view class="section-title">本月概况</view>
  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-number">{{totalAppt}}</text>
      <text class="stat-label">预约总数</text>
    </view>
    <view class="stat-card stat-card-blue">
      <text class="stat-number stat-number-white">{{completedAppt}}</text>
      <text class="stat-label stat-label-white">已完成预约</text>
    </view>
    <view class="stat-card stat-card-orange">
      <text class="stat-number stat-number-white">{{handledAlarms}}</text>
      <text class="stat-label stat-label-white">处理报警数</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{familyCount}}</text>
      <text class="stat-label">服务家庭数</text>
    </view>
  </view>

  <!-- Alarm Type Bar Chart -->
  <view class="section-title section-title-mt">报警类型 TOP 5</view>

  <view class="chart-wrap" wx:if="{{alarmTypeBars.length > 0}}">
    <view class="chart-row" wx:for="{{alarmTypeBars}}" wx:key="type">
      <text class="chart-label">{{item.type}}</text>
      <view class="bar-container">
        <view class="bar-fill" style="width:{{item.percent}}%;"></view>
      </view>
      <text class="chart-count">{{item.count}}</text>
    </view>
  </view>

  <view class="empty-chart" wx:else>
    <text class="hint-text">{{loading ? '加载中...' : '暂无报警数据'}}</text>
  </view>

</view>
