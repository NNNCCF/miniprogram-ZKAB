page {
  background: #f5f7fb;
  min-height: 100vh;
}

.page-body {
  min-height: calc(100vh - 140rpx);
  box-sizing: border-box;
  padding: 28rpx 28rpx calc(40rpx + env(safe-area-inset-bottom));
}

.hero-card {
  background: linear-gradient(135deg, #3b7eff 0%, #6ca5ff 100%);
  border-radius: 28rpx;
  padding: 32rpx;
  color: #ffffff;
  box-shadow: 0 14rpx 40rpx rgba(59, 126, 255, 0.18);
}

.hero-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
}

.hero-text {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.92);
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 24rpx;
}

.action-item {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 12rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 28, 56, 0.05);
}

.action-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon-blue {
  background: #eaf1ff;
}

.action-icon-green {
  background: #eafaf2;
}

.action-icon-orange {
  background: #fff3e8;
}

.action-icon-purple {
  background: #f3edff;
}

.action-icon-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #31569a;
}

.action-label {
  font-size: 22rpx;
  color: #46546f;
}

.section {
  margin-top: 28rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #17233a;
  margin-bottom: 14rpx;
  display: block;
}

.section-tip {
  font-size: 22rpx;
  color: #8c98ad;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(15, 28, 56, 0.05);
}

.faq-item,
.notice-item {
  padding: 28rpx 30rpx;
}

.faq-header,
.notice-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.faq-question {
  flex: 1;
  font-size: 28rpx;
  color: #17233a;
  line-height: 1.6;
}

.faq-arrow,
.notice-arrow {
  flex-shrink: 0;
  font-size: 30rpx;
  color: #c0c7d4;
  transition: transform 0.2s ease;
}

.faq-arrow-open {
  transform: rotate(90deg);
}

.faq-answer-wrap {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.25s ease, padding-top 0.25s ease;
}

.faq-answer-wrap-open {
  max-height: 240rpx;
  padding-top: 16rpx;
}

.faq-answer {
  font-size: 24rpx;
  line-height: 1.8;
  color: #69778f;
}

.notice-content {
  flex: 1;
}

.notice-title {
  display: block;
  font-size: 27rpx;
  color: #17233a;
  line-height: 1.6;
}

.notice-date {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #97a2b6;
}

.notice-empty {
  padding: 56rpx 24rpx;
  display: flex;
  justify-content: center;
}

.notice-empty-text {
  font-size: 24rpx;
  color: #97a2b6;
}

.divider {
  height: 1rpx;
  background: #eef1f6;
  margin: 0 30rpx;
}
