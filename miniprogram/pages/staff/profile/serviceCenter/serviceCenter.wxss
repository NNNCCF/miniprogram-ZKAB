/* ===== Page ===== */
page {
  background: #3B7EFF;
  min-height: 100vh;
}

.page-body {
  background: #F5F6FA;
  border-radius: 32rpx 32rpx 0 0;
  min-height: calc(100vh - 180rpx);
  padding: 24rpx 32rpx calc(60rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== Section Title ===== */
.section-title {
  font-size: 26rpx;
  color: #888;
  font-weight: 600;
  padding: 16rpx 8rpx 12rpx;
  letter-spacing: 1rpx;
}

/* ===== Card ===== */
.card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

/* ===== FAQ ===== */
.faq-item {
  padding: 0;
}

.faq-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx;
  gap: 16rpx;
}

.faq-q {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
  line-height: 1.5;
}

.faq-arrow {
  font-size: 40rpx;
  color: #ccc;
  line-height: 1;
  transition: transform 0.2s;
  display: inline-block;
  transform: rotate(0deg);
}

.faq-arrow--open {
  transform: rotate(90deg);
}

.faq-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
  padding: 0 36rpx;
}

.faq-body--open {
  max-height: 400rpx;
  padding: 0 36rpx 28rpx;
}

.faq-a {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* ===== Contact Row ===== */
.contact-row {
  display: flex;
  align-items: center;
  padding: 28rpx 36rpx;
  gap: 20rpx;
}

.contact-row:active {
  background: #F7F9FF;
}

.contact-icon-wrap {
  width: 68rpx;
  height: 68rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.contact-icon-blue { background: #EDF3FF; }
.contact-icon-green { background: #F0FFF4; }

.contact-icon-char {
  font-size: 32rpx;
  line-height: 1;
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.contact-label {
  font-size: 24rpx;
  color: #aaa;
}

.contact-value {
  font-size: 28rpx;
  color: #1a1a1a;
}

.contact-value--blue {
  color: #3B7EFF;
}

.contact-arrow {
  font-size: 40rpx;
  color: #ccc;
  line-height: 1;
}

/* ===== Divider ===== */
.divider {
  height: 1rpx;
  background: #F5F5F5;
  margin: 0 36rpx;
}
