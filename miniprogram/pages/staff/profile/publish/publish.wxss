/* ===== Page ===== */
page {
  background: #3B7EFF;
  min-height: 100vh;
}

.page-body {
  background: #F5F6FA;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  min-height: calc(100vh - 180rpx);
  padding: 32rpx 32rpx calc(60rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== Card ===== */
.card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 40rpx;
}

/* ===== Field Group ===== */
.field-group {
  padding: 28rpx 36rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: #888;
  margin-bottom: 20rpx;
  font-weight: 600;
}

.field-label.required::before {
  content: '* ';
  color: #FF4D4F;
}

/* ===== Text Input ===== */
.field-input {
  width: 100%;
  height: 64rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  background: #F5F6FA;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

/* ===== Radio Group ===== */
.radio-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  border-radius: 32rpx;
  background: #F5F6FA;
}

.radio-text {
  font-size: 26rpx;
  color: #333;
}

/* ===== Textarea ===== */
.field-textarea {
  width: 100%;
  min-height: 220rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  line-height: 1.8;
  background: #F5F6FA;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

/* ===== Char Count ===== */
.char-count {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.char-count-text {
  font-size: 24rpx;
  color: #aaa;
}

.char-count-warn {
  color: #FF4D4F;
}

/* ===== Family Search ===== */
.family-search-wrap {
  margin-top: 20rpx;
}

.family-input {
  background: #F5F6FA;
  border-radius: 12rpx;
  height: 72rpx;
  padding: 0 20rpx;
}

/* ===== Divider ===== */
.divider {
  height: 1rpx;
  background: #F5F5F5;
  margin: 0 36rpx;
}

/* ===== Submit Button ===== */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: #3B7EFF;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(59, 126, 255, 0.35);
}

.submit-btn:active {
  opacity: 0.85;
}
