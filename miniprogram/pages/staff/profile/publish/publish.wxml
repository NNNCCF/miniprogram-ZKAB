<staff-navbar title="消息发布" show-back="{{true}}" />

<view class="page-body">
  <view class="card">
    <!-- Title -->
    <view class="field-group">
      <text class="field-label required">标题</text>
      <input class="field-input" placeholder="请输入消息标题" value="{{form.title}}" bindinput="onInput" data-field="title" />
    </view>
    <view class="divider"></view>

    <!-- Type -->
    <view class="field-group">
      <text class="field-label required">类型</text>
      <radio-group bindchange="onTypeChange" class="radio-group">
        <label class="radio-item" wx:for="{{types}}" wx:key="value">
          <radio value="{{item.value}}" checked="{{item.value === form.type}}" color="#3B7EFF" />
          <text class="radio-text">{{item.label}}</text>
        </label>
      </radio-group>
    </view>
    <view class="divider"></view>

    <!-- Content -->
    <view class="field-group">
      <text class="field-label required">内容</text>
      <textarea
        class="field-textarea"
        placeholder="请输入消息内容（至少10字）"
        value="{{form.content}}"
        bindinput="onContentInput"
        auto-height
        maxlength="1000"
      />
      <view class="char-count">
        <text class="char-count-text {{form.content.length < 10 ? 'char-count-warn' : ''}}">
          {{form.content.length}}/1000
        </text>
      </view>
    </view>
    <view class="divider"></view>

    <!-- Target -->
    <view class="field-group">
      <text class="field-label required">目标家庭</text>
      <radio-group bindchange="onTargetChange" class="radio-group">
        <label class="radio-item">
          <radio value="all" checked="{{form.target === 'all'}}" color="#3B7EFF" />
          <text class="radio-text">全部家庭</text>
        </label>
        <label class="radio-item">
          <radio value="specific" checked="{{form.target === 'specific'}}" color="#3B7EFF" />
          <text class="radio-text">指定家庭</text>
        </label>
      </radio-group>
      <view wx:if="{{form.target === 'specific'}}" class="family-search-wrap">
        <input
          class="field-input family-input"
          placeholder="请输入家庭姓名搜索"
          value="{{form.familyName}}"
          bindinput="onInput"
          data-field="familyName"
        />
      </view>
    </view>
  </view>

  <button class="submit-btn" bindtap="onSubmit" loading="{{submitting}}">发布消息</button>
</view>
