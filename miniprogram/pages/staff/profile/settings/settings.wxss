/* ===== Page ===== */
page {
  background: #3B7EFF;
  min-height: 100vh;
}

.page-body {
  background: #F5F6FA;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  min-height: calc(100vh - 180rpx);
  padding: 24rpx 32rpx calc(60rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* ===== Section Title ===== */
.section-title {
  font-size: 26rpx;
  color: #888;
  font-weight: 600;
  padding: 16rpx 8rpx 12rpx;
  letter-spacing: 1rpx;
}

/* ===== Card ===== */
.card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

/* ===== Setting Row ===== */
.setting-row {
  display: flex;
  align-items: center;
  padding: 28rpx 36rpx;
  gap: 16rpx;
}

.setting-row:active {
  background: #F7F9FF;
}

.setting-label {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a1a;
}

.setting-sub {
  font-size: 26rpx;
  color: #aaa;
  margin-right: 8rpx;
}

.setting-arrow {
  font-size: 40rpx;
  color: #ccc;
  line-height: 1;
}

/* ===== Divider ===== */
.divider {
  height: 1rpx;
  background: #F5F5F5;
  margin: 0 36rpx;
}

/* ===== Logout ===== */
.logout-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 48rpx;
}

.logout-card:active {
  background: #FFF5F5;
}

.logout-text {
  font-size: 30rpx;
  color: #FF4D4F;
  font-weight: 600;
}

/* ===== Version ===== */
.version-text {
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
  margin-top: auto;
  padding-bottom: 16rpx;
}

/* ===== Modal ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 36rpx;
  width: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.modal-body {
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
  text-align: center;
  white-space: pre-line;
}

.modal-btn {
  width: 100%;
  height: 80rpx;
  background: #3B7EFF;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 8rpx;
}
