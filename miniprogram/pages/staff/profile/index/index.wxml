<staff-navbar title="我的" show-back="{{false}}" />

<view class="page-body">

  <!-- Profile Card -->
  <view class="profile-card">
    <view class="avatar-wrap">
      <view class="avatar">
        <text class="avatar-text">{{avatarText}}</text>
      </view>
    </view>
    <view class="profile-info">
      <text class="profile-name">{{doctorName}}</text>
      <text class="profile-org">{{orgName}}</text>
      <view class="role-tag">
        <text class="role-text">{{roleName}}</text>
      </view>
    </view>
  </view>

  <!-- Menu List -->
  <view class="menu-section">
    <!-- Group 1: Org & Personal -->
    <view class="menu-group">
      <view class="menu-item" bindtap="goToOrgInfo">
        <view class="menu-icon-wrap menu-icon-blue">
          <text class="menu-icon-char">🏥</text>
        </view>
        <text class="menu-label">机构信息</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="goToPersonalInfo">
        <view class="menu-icon-wrap menu-icon-green">
          <text class="menu-icon-char">👤</text>
        </view>
        <text class="menu-label">个人信息</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- Group 2: Work Features -->
    <view class="menu-group">
      <view class="menu-item" bindtap="goToMap">
        <view class="menu-icon-wrap menu-icon-orange">
          <text class="menu-icon-char">🗺</text>
        </view>
        <text class="menu-label">地图总览</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="goToSummary">
        <view class="menu-icon-wrap menu-icon-purple">
          <text class="menu-icon-char">📋</text>
        </view>
        <text class="menu-label">上门汇总</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="goToPublish">
        <view class="menu-icon-wrap menu-icon-teal">
          <text class="menu-icon-char">📢</text>
        </view>
        <text class="menu-label">消息发布</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- Group 3: Support -->
    <view class="menu-group">
      <view class="menu-item" bindtap="goToServiceCenter">
        <view class="menu-icon-wrap menu-icon-blue">
          <text class="menu-icon-char">🎧</text>
        </view>
        <text class="menu-label">服务中心</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="goToFeedback">
        <view class="menu-icon-wrap menu-icon-yellow">
          <text class="menu-icon-char">💬</text>
        </view>
        <text class="menu-label">意见反馈</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="goToSettings">
        <view class="menu-icon-wrap menu-icon-gray">
          <text class="menu-icon-char">⚙</text>
        </view>
        <text class="menu-label">系统设置</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- Logout -->
    <view class="logout-btn" bindtap="onLogout">
      <text class="logout-text">退出登录</text>
    </view>
  </view>

</view>

<staff-tabbar active="profile" />
