/* ===== Page Layout ===== */
page {
  background: linear-gradient(165deg, #ffffff 0%, #ffffff 100%);
  min-height: 100vh;
}

.page-body {
  background: #F2F5FC;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  min-height: calc(100vh - 180rpx);
  padding: 0 0 calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
      transform: translateY(32rpx);
}

/* ===== Profile Card ===== */
.profile-card {
  background: #fff;
  border-radius: 0 0 28rpx 28rpx;
  padding: 40rpx 40rpx 48rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 28rpx rgba(43, 107, 224, 0.10);
}

.avatar-wrap {
  flex-shrink: 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1B3A70 0%, #3B7EFF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(59, 126, 255, 0.42);
}

.avatar-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: 700;
}

.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #0F1C38;
  letter-spacing: 1rpx;
}

.profile-org {
  font-size: 26rpx;
  color: #8A94A8;
}

.role-tag {
  display: inline-flex;
  align-self: flex-start;
  background: #EBF1FF;
  border-radius: 8rpx;
  padding: 4rpx 16rpx;
}

.role-text {
  font-size: 22rpx;
  color: #3B7EFF;
  font-weight: 600;
}

/* ===== Menu Section ===== */
.menu-section {
  padding: 0 28rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ===== Menu Group ===== */
.menu-group {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(43, 107, 224, 0.06);
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  background: #fff;
}

.menu-item:active {
  background: #F5F8FF;
}

.menu-divider {
  height: 1rpx;
  background: #EEF2FA;
  margin: 0 32rpx;
}

/* Menu icon wrap */
.menu-icon-wrap {
  width: 68rpx;
  height: 68rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon-blue   { background: #EBF1FF; }
.menu-icon-green  { background: #EDFAF3; }
.menu-icon-orange { background: #FFF5E8; }
.menu-icon-purple { background: #F3EEFF; }
.menu-icon-teal   { background: #E6FAF8; }
.menu-icon-yellow { background: #FFFCE8; }
.menu-icon-gray   { background: #F2F4F8; }

.menu-icon-char {
  font-size: 36rpx;
  line-height: 1;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #0F1C38;
}

.menu-arrow {
  font-size: 40rpx;
  color: #C8D0E0;
  line-height: 1;
}

/* ===== Logout Button ===== */
.logout-btn {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 16rpx rgba(43, 107, 224, 0.06);
}

.logout-btn:active {
  background: #FFF5F5;
}

.logout-text {
  font-size: 30rpx;
  color: #E63A35;
  font-weight: 600;
}
