/* ===== Page Layout ===== */
page {
  background: #3B7EFF;
  min-height: 100vh;
}

.page-body {
  background: #F5F6FA;
  border-radius: 32rpx 32rpx 0 0;
  min-height: calc(100vh - 180rpx);
  padding: 0 0 calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== Profile Card ===== */
.profile-card {
  background: #fff;
  border-radius: 0 0 32rpx 32rpx;
  padding: 40rpx 40rpx 48rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(59, 126, 255, 0.08);
}

.avatar-wrap {
  flex-shrink: 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3B7EFF 0%, #5B9BFF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(59, 126, 255, 0.35);
}

.avatar-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: 700;
}

.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1a1a;
}

.profile-org {
  font-size: 26rpx;
  color: #888;
}

.role-tag {
  display: inline-flex;
  align-self: flex-start;
  background: #EDF3FF;
  border-radius: 8rpx;
  padding: 4rpx 16rpx;
}

.role-text {
  font-size: 22rpx;
  color: #3B7EFF;
  font-weight: 600;
}

/* ===== Menu Section ===== */
.menu-section {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ===== Menu Group ===== */
.menu-group {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  background: #fff;
}

.menu-item:active {
  background: #F7F9FF;
}

.menu-divider {
  height: 1rpx;
  background: #F5F5F5;
  margin: 0 32rpx;
}

/* Menu icon wrap */
.menu-icon-wrap {
  width: 68rpx;
  height: 68rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-icon-blue   { background: #EDF3FF; }
.menu-icon-green  { background: #F0FFF4; }
.menu-icon-orange { background: #FFF7E6; }
.menu-icon-purple { background: #F5F0FF; }
.menu-icon-teal   { background: #E6FFFB; }
.menu-icon-yellow { background: #FFFBE6; }
.menu-icon-gray   { background: #F5F5F5; }

.menu-icon-char {
  font-size: 36rpx;
  line-height: 1;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a1a;
}

.menu-arrow {
  font-size: 40rpx;
  color: #ccc;
  line-height: 1;
}

/* ===== Logout Button ===== */
.logout-btn {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.logout-btn:active {
  background: #FFF5F5;
}

.logout-text {
  font-size: 30rpx;
  color: #FF4D4F;
  font-weight: 600;
}
