/* ===== Page ===== */
page {
  background: #3B7EFF;
  min-height: 100vh;
}

.page-body {
  background: #F5F6FA;
  border-radius: 32rpx 32rpx 0 0;
  min-height: calc(100vh - 180rpx);
  padding: 32rpx 32rpx calc(60rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== Card ===== */
.card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 40rpx;
}

/* ===== Form Row ===== */
.form-row {
  display: flex;
  align-items: center;
  padding: 0 36rpx;
  height: 96rpx;
  gap: 24rpx;
}

.form-label {
  flex-shrink: 0;
  width: 160rpx;
  font-size: 28rpx;
  color: #555;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  text-align: right;
}

.form-value-readonly {
  flex: 1;
  font-size: 28rpx;
  color: #aaa;
  text-align: right;
}

/* ===== Divider ===== */
.divider {
  height: 1rpx;
  background: #F5F5F5;
  margin: 0 36rpx;
}

/* ===== Save Button ===== */
.save-btn {
  width: 100%;
  height: 96rpx;
  background: #3B7EFF;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(59, 126, 255, 0.35);
}

.save-btn:active {
  opacity: 0.85;
}
