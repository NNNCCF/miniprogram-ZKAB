<staff-navbar title="个人信息" show-back="{{true}}" />

<view class="page-body">
  <view class="card">
    <view class="form-row">
      <text class="form-label">姓名</text>
      <input class="form-input" placeholder="请输入姓名" value="{{form.name}}" bindinput="onInput" data-field="name" />
    </view>
    <view class="divider"></view>
    <view class="form-row">
      <text class="form-label">手机号</text>
      <text class="form-value-readonly">{{form.phone || '—'}}</text>
    </view>
    <view class="divider"></view>
    <view class="form-row">
      <text class="form-label">专业科室</text>
      <input class="form-input" placeholder="请输入专业科室" value="{{form.department}}" bindinput="onInput" data-field="department" />
    </view>
    <view class="divider"></view>
    <view class="form-row">
      <text class="form-label">职称</text>
      <input class="form-input" placeholder="请输入职称" value="{{form.title}}" bindinput="onInput" data-field="title" />
    </view>
    <view class="divider"></view>
    <view class="form-row">
      <text class="form-label">身份证号</text>
      <input class="form-input" placeholder="请输入身份证号" value="{{form.idCard}}" bindinput="onInput" data-field="idCard" />
    </view>
  </view>

  <button class="save-btn" bindtap="onSave" loading="{{saving}}">保存</button>
</view>
