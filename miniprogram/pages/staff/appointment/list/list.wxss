/* ===== Page Layout ===== */
page {
  background: #3B7EFF;
  min-height: 100vh;
}

.page-body {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  min-height: calc(100vh - 180rpx);
  padding: 24rpx 0 calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== Filter Bar ===== */
.filter-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 32rpx 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
    transform: translateY(24rpx);
}

.month-picker {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #F5F7FF;
  border-radius: 12rpx;
  padding: 10rpx 18rpx;
  flex-shrink: 0;
}

.month-text {
  font-size: 26rpx;
  color: #3B7EFF;
  font-weight: 600;
}

.picker-arrow {
  font-size: 22rpx;
  color: #3B7EFF;
}

.search-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #F5F6FA;
  border-radius: 40rpx;
  padding: 10rpx 20rpx;
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
  opacity: 0.4;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  height: 44rpx;
}

/* ===== Type Scroll ===== */
.type-scroll {
  white-space: nowrap;
  padding: 20rpx 32rpx 0;
}

.type-list {
  display: inline-flex;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

.type-tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  border: 2rpx solid #E0E6F5;
  background: #F7F9FF;
  white-space: nowrap;
  flex-shrink: 0;
}

.type-tag text {
  font-size: 26rpx;
  color: #666;
}

.type-tag-active {
  background: #3B7EFF;
  border-color: #3B7EFF;
}

.type-tag-active text {
  color: #fff;
}

/* ===== Status Filter Row ===== */
.status-filter-row {
  display: flex;
  gap: 0;
  padding: 20rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.status-filter {
  flex: 1;
  text-align: center;
  padding: 10rpx 0;
  font-size: 26rpx;
  color: #888;
  border-bottom: 4rpx solid transparent;
}

.status-filter-active {
  color: #3B7EFF;
  font-weight: 600;
  border-bottom-color: #3B7EFF;
}

/* ===== Appointment Cards ===== */
.appt-list {
  padding: 20rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.appt-card {
  background: #F7F9FF;
  border-radius: 20rpx;
  padding: 24rpx;
  position: relative;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.card-type-wrap {
  display: flex;
  align-items: center;
}

.card-type {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

/* Status badges */
.status-badge {
  padding: 4rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.status-badge.status-pending   { background: #FFF3E8; }
.status-badge.status-accepted  { background: #EDF3FF; }
.status-badge.status-completed { background: #F0F0F0; }

.status-badge.status-pending   .status-text { color: #FF8C00; }
.status-badge.status-accepted  .status-text { color: #3B7EFF; }
.status-badge.status-completed .status-text { color: #999;    }

/* Card rows */
.card-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.card-label {
  font-size: 24rpx;
  color: #aaa;
  flex-shrink: 0;
  min-width: 96rpx;
}

.card-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.card-notes {
  color: #888;
}

.card-arrow {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
}

.arrow-icon {
  font-size: 40rpx;
  color: #ccc;
}

/* ===== Empty & Loading ===== */
.empty-wrap,
.loading-wrap {
  padding: 80rpx 0;
  display: flex;
  justify-content: center;
}

.empty-text,
.loading-text {
  font-size: 28rpx;
  color: #ccc;
}
