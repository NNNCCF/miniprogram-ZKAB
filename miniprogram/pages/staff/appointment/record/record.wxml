<staff-navbar title="上门记录" show-back="{{true}}" />

<view class="page-body">

  <!-- Visit Date Picker -->
  <view class="field-group">
    <text class="field-label required-label">实际上门日期</text>
    <picker mode="date" value="{{form.visitDate}}" bindchange="onVisitDateChange">
      <view class="picker-trigger">
        <text class="picker-text {{form.visitDate ? '' : 'placeholder'}}">
          {{form.visitDate || '请选择上门日期'}}
        </text>
        <text class="picker-arrow">›</text>
      </view>
    </picker>
  </view>

  <!-- Remark -->
  <view class="field-group">
    <text class="field-label required-label">服务备注</text>
    <textarea
      class="field-textarea"
      placeholder="请描述本次服务情况、健康观察及跟进计划..."
      value="{{form.remark}}"
      bindinput="onRemarkInput"
      maxlength="500"
      auto-height
    />
    <text class="char-count">{{form.remark.length}}/500</text>
  </view>

  <!-- Pay Amount -->
  <view class="field-group">
    <text class="field-label">收费金额（元）</text>
    <input
      class="field-input"
      type="digit"
      placeholder="选填"
      value="{{form.payAmount}}"
      bindinput="onPayAmountInput"
    />
  </view>

  <!-- Pay Status -->
  <view class="field-group">
    <text class="field-label">付款状态</text>
    <view class="pay-options">
      <view
        class="pay-opt {{form.payStatus === 'unpaid' ? 'opt-active' : ''}}"
        bindtap="onPayStatusChange"
        data-status="unpaid"
      >未付款</view>
      <view
        class="pay-opt {{form.payStatus === 'paid' ? 'opt-active' : ''}}"
        bindtap="onPayStatusChange"
        data-status="paid"
      >已付款</view>
    </view>
  </view>

  <!-- Submit -->
  <button
    class="submit-btn {{submitting ? 'btn-disabled' : ''}}"
    bindtap="handleSubmit"
    disabled="{{submitting}}"
  >
    {{submitting ? '提交中...' : '提交上门记录'}}
  </button>

</view>
