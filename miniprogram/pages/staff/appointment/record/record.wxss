page {
  background: #3B7EFF;
  min-height: 100vh;
}

.page-body {
  background: #F5F7FF;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  height: calc(100vh - 88rpx);
  box-sizing: border-box;
}

/* ===== Section ===== */
.section {
  background: #fff;
  border-radius: 20rpx;
  margin: 20rpx 24rpx 0;
  padding: 28rpx 28rpx 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-label {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.required-label::before {
  content: '* ';
  color: #FF4D4F;
}

.photo-count {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* ===== Picker ===== */
.picker-row {
  height: 88rpx;
  background: #F7F9FF;
  border-radius: 16rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.picker-val {
  font-size: 28rpx;
  color: #1a1a1a;
}

.picker-val.placeholder {
  color: #bbb;
}

.picker-arrow {
  font-size: 40rpx;
  color: #ccc;
}

/* ===== Pill Group ===== */
.pill-group {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.pill {
  flex: 1;
  min-width: 120rpx;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F7F9FF;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.pill-text {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

/* Service result pills */
.pill-result-0 { background: #F0FFF4; }
.pill-result-1 { background: #FFFBEB; }
.pill-result-2 { background: #FFF5F5; }

/* Active state */
.pill-active {
  border-color: #3B7EFF;
  background: #EEF4FF !important;
}

.pill-active .pill-text {
  color: #3B7EFF;
  font-weight: 700;
}

/* Elder status colors */
.pill-status-0 { background: #F0FFF4; }
.pill-status-1 { background: #FFFBEB; }
.pill-status-2 { background: #FFF7E6; }
.pill-status-3 { background: #FFF5F5; }

/* ===== Textarea ===== */
.field-textarea {
  background: #F7F9FF;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  min-height: 140rpx;
  width: 100%;
  box-sizing: border-box;
  line-height: 1.7;
}

.mt16 { margin-top: 16rpx; }

/* ===== Photo Grid ===== */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-del {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-del-icon {
  font-size: 28rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}

.photo-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #F7F9FF;
  border: 2rpx dashed #D1D5DB;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.photo-add-icon {
  font-size: 52rpx;
  color: #9CA3AF;
  line-height: 1;
}

.photo-add-text {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* ===== Fee ===== */
.fee-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.fee-label {
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
  width: 160rpx;
}

.fee-input {
  flex: 1;
  height: 80rpx;
  background: #F7F9FF;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  box-sizing: border-box;
}

/* ===== Pay Options ===== */
.pay-options {
  display: flex;
  gap: 20rpx;
}

.pay-opt {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  background: #F7F9FF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.opt-active {
  background: #EEF4FF;
  border-color: #3B7EFF;
  color: #3B7EFF;
  font-weight: 600;
}

/* ===== Submit ===== */
.submit-wrap {
  padding: 32rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: #3B7EFF;
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.btn-disabled {
  background: #A0BEFF;
}
