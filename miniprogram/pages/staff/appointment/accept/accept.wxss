page {
  background: #3B7EFF;
  min-height: 100vh;
}

.page-body {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  min-height: calc(100vh - 180rpx);
  padding: 48rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

/* ===== Field Group ===== */
.field-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.field-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.required-label::before {
  content: '* ';
  color: #FF4D4F;
}

/* ===== Input ===== */
.field-input {
  background: #F7F9FF;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 88rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  box-sizing: border-box;
}

/* ===== Submit Button ===== */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: #3B7EFF;
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-top: auto;
}

.btn-disabled {
  background: #A0BEFF;
}
