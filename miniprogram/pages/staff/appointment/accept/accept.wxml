<staff-navbar title="指派护士" show-back="{{true}}" />

<view class="page-body">

  <!-- Nurse Name -->
  <view class="field-group">
    <text class="field-label required-label">护士姓名</text>
    <input
      class="field-input"
      type="text"
      placeholder="请输入负责护士姓名"
      value="{{nurseName}}"
      bindinput="onNurseNameInput"
    />
  </view>

  <!-- Submit -->
  <button
    class="submit-btn {{submitting ? 'btn-disabled' : ''}}"
    bindtap="handleSubmit"
    disabled="{{submitting}}"
  >
    {{submitting ? '提交中...' : '确认指派'}}
  </button>

</view>
