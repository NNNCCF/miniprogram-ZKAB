<staff-navbar title="预约详情" show-back="{{true}}" />

<view class="page-body" wx:if="{{!loading && appt}}">

  <!-- Status Banner -->
  <view class="status-banner status-{{appt.status}}">
    <text class="status-banner-text">{{appt.statusLabel}}</text>
  </view>

  <!-- Appointment Base Info -->
  <view class="section-title">预约信息</view>
  <view class="info-card">
    <view class="info-row">
      <text class="info-label">预约类型</text>
      <text class="info-value">{{appt.type}}</text>
    </view>
    <view class="divider"></view>
    <view class="info-row">
      <text class="info-label">预约时间</text>
      <text class="info-value">{{appt.appointmentTime}}</text>
    </view>
    <view class="divider"></view>
    <view class="info-row">
      <text class="info-label">备注</text>
      <text class="info-value info-notes">{{appt.notes || '无'}}</text>
    </view>
  </view>

  <!-- Member Info -->
  <view class="section-title">成员信息</view>
  <view class="info-card">
    <view class="info-row">
      <text class="info-label">成员姓名</text>
      <text class="info-value">{{appt.memberName}}</text>
    </view>
    <view class="divider"></view>
    <view class="info-row">
      <text class="info-label">联系电话</text>
      <text class="info-value">{{appt.memberPhone || '—'}}</text>
    </view>
    <view class="divider"></view>
    <view class="info-row">
      <text class="info-label">家庭地址</text>
      <text class="info-value">{{appt.memberAddress || '—'}}</text>
    </view>
  </view>

  <!-- Doctor Info -->
  <view class="section-title">负责医护</view>
  <view class="info-card">
    <view class="info-row">
      <text class="info-label">医护姓名</text>
      <text class="info-value">{{appt.doctorName || '—'}}</text>
    </view>
    <view class="divider"></view>
    <view class="info-row">
      <text class="info-label">联系方式</text>
      <text class="info-value">{{appt.doctorPhone || '—'}}</text>
    </view>
  </view>

  <!-- Completed: Record Summary -->
  <view wx:if="{{appt.status === 'completed' && appt.record}}">
    <view class="section-title">上门记录摘要</view>
    <view class="section-card">
      <view class="record-row">
        <text class="record-label">服务内容</text>
        <text class="record-value">{{appt.record.serviceContent || '—'}}</text>
      </view>
      <view class="record-row">
        <text class="record-label">健康观察</text>
        <text class="record-value">{{appt.record.healthObservation || '—'}}</text>
      </view>
      <view class="record-row">
        <text class="record-label">跟进计划</text>
        <text class="record-value">{{appt.record.followUpPlan || '—'}}</text>
      </view>
    </view>
  </view>

</view>

<view class="center-wrap" wx:if="{{loading}}">
  <text class="hint-text">加载中...</text>
</view>

<!-- Bottom Action -->
<view class="bottom-bar" wx:if="{{!loading && appt}}">
  <button class="btn-primary" wx:if="{{appt.status === 'pending'}}" bindtap="goToAccept">
    接受预约
  </button>
  <button class="btn-primary" wx:elif="{{appt.status === 'accepted'}}" bindtap="goToRecord">
    填写记录
  </button>
  <button class="btn-secondary btn-full" wx:else bindtap="goBack">返回列表</button>
</view>
