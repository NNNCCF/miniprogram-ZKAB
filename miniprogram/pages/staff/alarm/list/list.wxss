/* ===== Page Layout ===== */
page {
  background: linear-gradient(165deg, #ffffff 0%, #ffffff 100%);
  min-height: 100vh;
}

.page-body {
  background: #F2F5FC;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  min-height: calc(100vh - 180rpx);
  padding: 0 0 calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== Tab Bar ===== */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #E8EEF8;
  padding: 0 32rpx;
      transform: translateY(24rpx);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 32rpx 0;
  font-size: 28rpx;
  color: #9CA3B4;
  border-bottom: 4rpx solid transparent;
  margin-bottom: -1rpx;
  position: relative;
}

.tab-active {
  color: #3B7EFF;
  font-weight: 700;
  border-bottom-color: #3B7EFF;
}

.tab-dot {
  background: #E63A35;
  border-radius: 20rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-dot-text {
  font-size: 20rpx;
  color: #fff;
  line-height: 1;
}

/* ===== Alarm List ===== */
.alarm-list {
  padding: 24rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.alarm-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 24rpx 24rpx 28rpx;
  position: relative;
  box-shadow: 0 2rpx 16rpx rgba(43, 107, 224, 0.07);
  overflow: hidden;
}

/* Red dot indicator */
.red-dot {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #E63A35;
}

/* Alarm icon */
.card-left {
  flex-shrink: 0;
}

.alarm-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.alarm-unhandled {
  background: #FFF0F0;
}

.alarm-handled {
  background: #F2F4F8;
}

.alarm-icon-text {
  font-size: 34rpx;
  font-weight: 900;
  color: #E63A35;
}

.alarm-handled .alarm-icon-text {
  color: #C0C8D8;
}

/* Card main content */
.card-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.card-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.member-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0F1C38;
}

.status-badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.status-badge.status-unhandled { background: #FFF0F0; }
.status-badge.status-handled   { background: #F2F4F8; }

.status-badge.status-unhandled .status-text { color: #E63A35; }
.status-badge.status-handled   .status-text { color: #9CA3B4; }

.alarm-type {
  font-size: 26rpx;
  color: #4A587A;
}

.alarm-time {
  font-size: 24rpx;
  color: #9CA3B4;
}

/* Arrow */
.card-arrow {
  flex-shrink: 0;
}

.arrow-icon {
  font-size: 40rpx;
  color: #C8D0E0;
}

/* ===== Empty & Loading ===== */
.empty-wrap,
.loading-wrap {
  padding: 100rpx 0;
  display: flex;
  justify-content: center;
}

.empty-text,
.loading-text {
  font-size: 28rpx;
  color: #C0C8D8;
}
