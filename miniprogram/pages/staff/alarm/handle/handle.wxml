<staff-navbar title="处理报警" show-back="{{true}}" />

<view class="page-body">

  <!-- Called Guardian Switch -->
  <view class="field-group">
    <view class="field-row">
      <text class="field-label">是否已联系监护人</text>
      <switch checked="{{form.calledGuardian}}" bindchange="onCalledGuardianChange" color="#3B7EFF" />
    </view>
  </view>

  <!-- Member Danger Switch -->
  <view class="field-group">
    <view class="field-row">
      <text class="field-label">成员是否处于危险</text>
      <switch checked="{{form.memberDanger}}" bindchange="onMemberDangerChange" color="#FF4B4B" />
    </view>
  </view>

  <!-- Remark Textarea -->
  <view class="field-group">
    <text class="field-label">处理备注 <text class="required">*</text></text>
    <textarea
      class="field-textarea"
      placeholder="请描述处理过程和结果..."
      value="{{form.remark}}"
      bindinput="onRemarkInput"
      maxlength="500"
      auto-height
    />
    <text class="char-count">{{form.remark.length}}/500</text>
  </view>

  <!-- Submit -->
  <button
    class="submit-btn {{submitting ? 'btn-disabled' : ''}}"
    bindtap="handleSubmit"
    disabled="{{submitting}}"
  >
    {{submitting ? '提交中...' : '提交处理结果'}}
  </button>

</view>
