page {
  background: #3B7EFF;
  min-height: 100vh;
}

.page-body {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  min-height: calc(100vh - 180rpx);
  padding: 48rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

/* ===== Field Group ===== */
.field-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.field-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

/* ===== Field Row (label + switch) ===== */
.field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F7F9FF;
  border-radius: 16rpx;
  padding: 24rpx;
}

.required {
  color: #FF4B4B;
}

/* ===== Textarea ===== */
.field-textarea {
  background: #F7F9FF;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  min-height: 200rpx;
  width: 100%;
  box-sizing: border-box;
  line-height: 1.7;
}

.char-count {
  font-size: 22rpx;
  color: #bbb;
  text-align: right;
}

/* ===== Submit Button ===== */
.submit-btn {
  width: 100%;
  height: 96rpx;
  background: #3B7EFF;
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-top: auto;
}

.btn-disabled {
  background: #A0BEFF;
}
