page {
  background: #3B7EFF;
  min-height: 100vh;
}

.page-body {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  min-height: calc(100vh - 180rpx);
  padding: 40rpx 32rpx calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== Header ===== */
.alarm-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 40rpx;
  padding: 32rpx;
  background: #FFF8F8;
  border-radius: 20rpx;
}

.alarm-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.alarm-red   { background: #FFF1F0; }
.alarm-orange { background: #FFF7E6; }
.alarm-yellow { background: #FFFBE6; }

.alarm-icon-text {
  font-size: 48rpx;
  font-weight: 900;
  color: #FF4D4F;
}

.alarm-orange .alarm-icon-text { color: #FA8C16; }
.alarm-yellow .alarm-icon-text { color: #FADB14; }

.header-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.member-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.level-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  align-self: flex-start;
}

.level-red    { background: #FFF1F0; }
.level-orange { background: #FFF7E6; }
.level-yellow { background: #FFFBE6; }

.level-text { font-size: 24rpx; font-weight: 500; }
.level-red .level-text    { color: #FF4D4F; }
.level-orange .level-text { color: #FA8C16; }
.level-yellow .level-text { color: #D4B106; }

/* ===== Info Card ===== */
.info-card {
  background: #F7F9FF;
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
  width: 160rpx;
}

.info-value {
  font-size: 28rpx;
  color: #1a1a1a;
  text-align: right;
  flex: 1;
}

.divider {
  height: 1rpx;
  background: #EBEBEB;
}

/* ===== Section Card ===== */
.section-card {
  background: #F7F9FF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.section-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

/* ===== Status Row ===== */
.status-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 0;
}

.status-label-text {
  font-size: 28rpx;
  color: #666;
}

.status-badge {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.status-unhandled { background: #FFF1F0; }
.status-handling  { background: #FFF7E6; }
.status-handled   { background: #F0F7FF; }

.status-text { font-size: 24rpx; font-weight: 500; }
.status-unhandled .status-text { color: #FF4D4F; }
.status-handling .status-text  { color: #FA8C16; }
.status-handled .status-text   { color: #3B7EFF; }

/* ===== Bottom Bar ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #F0F0F0;
  display: flex;
  gap: 20rpx;
}

.btn-primary {
  flex: 1;
  height: 88rpx;
  background: #3B7EFF;
  border-radius: 44rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-full { flex: unset; width: 100%; }

.btn-secondary {
  flex: 1;
  height: 88rpx;
  background: #fff;
  border-radius: 44rpx;
  color: #3B7EFF;
  font-size: 30rpx;
  font-weight: 600;
  border: 2rpx solid #3B7EFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

/* ===== Center Wrap ===== */
.center-wrap {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.hint-text {
  font-size: 28rpx;
  color: #ccc;
}
