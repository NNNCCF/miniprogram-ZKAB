page {
  background: #000;
  height: 100vh;
  overflow: hidden;
}

.page {
  position: relative;
  height: 100vh;
}

/* ===== 地图全屏 ===== */
.map {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
}

/* ===== 底部抽屉面板 ===== */
.bottom-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: calc(88rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  box-shadow: 0 -8rpx 40rpx rgba(15, 28, 56, 0.14);
  padding-bottom: 8rpx;
}

/* ===== 把手 ===== */
.panel-handle-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14rpx 0 10rpx;
  gap: 8rpx;
}

.panel-handle {
  width: 64rpx;
  height: 8rpx;
  background: #D8E0F0;
  border-radius: 4rpx;
}

.panel-arrow {
  font-size: 24rpx;
  color: #C0C8D8;
  line-height: 1;
  transition: transform 0.3s ease;
  display: block;
}

.arrow-down {
  transform: rotate(180deg);
}

.arrow-up {
  transform: rotate(0deg);
}

/* ===== 可折叠内容区 ===== */
.panel-body {
  overflow: hidden;
  max-height: 400rpx;
  transition: max-height 0.3s ease;
}

.panel-body-closed {
  max-height: 0;
}

/* ===== 筛选栏 ===== */
.filter-row {
  display: flex;
  align-items: center;
  padding: 4rpx 24rpx 16rpx;
  gap: 16rpx;
}

.filter-chip {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 68rpx;
  border-radius: 34rpx;
  background: #F2F5FC;
  transition: background 0.15s;
}

.filter-chip-active {
  background: #EBF1FF;
}

.filter-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.filter-label {
  font-size: 24rpx;
  color: #8A94A8;
}

.filter-chip-active .filter-label {
  color: #3B7EFF;
  font-weight: 600;
}

/* ===== 分割线 ===== */
.panel-divider {
  height: 1rpx;
  background: #EBF0FA;
  margin: 0 28rpx 4rpx;
}

/* ===== 统计数据 ===== */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
}

.stat-item {
  width: 33.333%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 24rpx;
  box-sizing: border-box;
  position: relative;
}

/* 纵向分割线 */
.stat-item:not(:nth-child(3n))::after {
  content: '';
  position: absolute;
  right: 0;
  top: 20rpx;
  bottom: 20rpx;
  width: 1rpx;
  background: #E8EEF8;
}

/* 第二行横向分割线 */
.stat-item:nth-child(4),
.stat-item:nth-child(5),
.stat-item:nth-child(6) {
  border-top: 1rpx solid #E8EEF8;
}

.stat-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #3B7EFF;
  line-height: 1.15;
  letter-spacing: -0.5rpx;
}

.stat-num.stat-alarm {
  color: #E63A35;
}

.stat-label {
  font-size: 22rpx;
  color: #9CA3B4;
  margin-top: 6rpx;
  letter-spacing: 0.5rpx;
}

/* ===== News Section (in panel) ===== */
.news-section {
  padding: 12rpx 28rpx 8rpx;
  border-top: 1rpx solid #EBF0FA;
}

.news-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.news-section-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #8A94A8;
}

.news-more-btn {
  font-size: 20rpx;
  color: #3B7EFF;
}

.news-empty-sm {
  padding: 8rpx 0;
}

.news-empty-text-sm {
  font-size: 22rpx;
  color: #BCC4D6;
}

.news-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 0;
}

.news-dot-sm {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #3B7EFF;
  flex-shrink: 0;
}

.news-text-sm {
  flex: 1;
  font-size: 22rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.news-arrow-sm {
  font-size: 24rpx;
  color: #ccc;
  flex-shrink: 0;
}
