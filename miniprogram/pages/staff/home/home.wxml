<view class="page">

  <!-- 地图 -->
  <map
    id="map"
    class="map"
    latitude="{{mapLat}}"
    longitude="{{mapLng}}"
    scale="{{mapScale}}"
    markers="{{markers}}"
    bindmarkertap="onMarkerTap"
    bindtap="onMapTap"
    show-location
    enable-scroll
    enable-zoom
  />

  <!-- 地图筛选栏 -->
  <view class="filter-bar">
    <view
      wx:for="{{filters}}"
      wx:key="key"
      class="filter-item {{item.active ? 'filter-active' : ''}}"
      bindtap="onFilter"
      data-key="{{item.key}}"
    >
      <image class="filter-icon" src="{{item.icon}}" mode="aspectFit" />
      <text class="filter-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 统计区域 -->
  <view class="stats-wrap">
    <view class="stats-grid">
      <view class="stat-item" bindtap="goToArchive">
        <text class="stat-num">{{stats.families}}</text>
        <text class="stat-label">服务家庭数量</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.members}}</text>
        <text class="stat-label">监护人员数量</text>
      </view>
      <view class="stat-item" bindtap="goToAlarm">
        <text class="stat-num stat-alarm">{{stats.todayAlarms}}</text>
        <text class="stat-label">今日报警数量</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.nurses}}</text>
        <text class="stat-label">医护人员数量</text>
      </view>
      <view class="stat-item" bindtap="goToAppt">
        <text class="stat-num">{{stats.totalAppts}}</text>
        <text class="stat-label">预约上门总数</text>
      </view>
      <view class="stat-item" bindtap="goToAppt">
        <text class="stat-num">{{stats.todayVisits}}</text>
        <text class="stat-label">今日上门数量</text>
      </view>
    </view>
  </view>

</view>

<staff-tabbar active="home" alarm-count="{{stats.todayAlarms}}" appt-count="{{stats.pendingAppts}}" />
