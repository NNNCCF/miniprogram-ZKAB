<view class="page">

  <!-- 地图：全屏铺满 -->
  <map
    id="map"
    class="map"
    latitude="{{mapLat}}"
    longitude="{{mapLng}}"
    scale="{{mapScale}}"
    markers="{{markers}}"
    bindmarkertap="onMarkerTap"
    bindtap="onMapTap"
    show-location
    enable-scroll
    enable-zoom
  />

  <!-- 底部抽屉面板 -->
  <view class="bottom-panel">

    <!-- 把手（点击收起/展开） -->
    <view class="panel-handle-wrap" bindtap="togglePanel">
      <view class="panel-handle"></view>
      <text class="panel-arrow {{panelOpen ? 'arrow-down' : 'arrow-up'}}">⌃</text>
    </view>

    <!-- 可折叠内容区 -->
    <view class="panel-body {{panelOpen ? '' : 'panel-body-closed'}}">

    <!-- 筛选栏 -->
    <view class="filter-row">
      <view
        wx:for="{{filters}}"
        wx:key="key"
        class="filter-chip {{item.active ? 'filter-chip-active' : ''}}"
        bindtap="onFilter"
        data-key="{{item.key}}"
      >
        <image class="filter-icon" src="{{item.icon}}" mode="aspectFit" />
        <text class="filter-label">{{item.label}}</text>
      </view>
    </view>

    <!-- 分割线 -->
    <view class="panel-divider"></view>

    <!-- 统计数据 -->
    <view class="stats-grid">
      <view class="stat-item" bindtap="goToArchive">
        <text class="stat-num">{{stats.families}}</text>
        <text class="stat-label">服务家庭</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.members}}</text>
        <text class="stat-label">监护人员</text>
      </view>
      <view class="stat-item" bindtap="goToAlarm">
        <text class="stat-num stat-alarm">{{stats.todayAlarms}}</text>
        <text class="stat-label">今日报警</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.nurses}}</text>
        <text class="stat-label">医护人员</text>
      </view>
      <view class="stat-item" bindtap="goToAppt">
        <text class="stat-num">{{stats.totalAppts}}</text>
        <text class="stat-label">预约总数</text>
      </view>
      <view class="stat-item" bindtap="goToAppt">
        <text class="stat-num">{{stats.todayVisits}}</text>
        <text class="stat-label">今日上门</text>
      </view>
    </view>

    <!-- 健康动态（简要） -->
    <view class="news-section">
      <view class="news-section-header" bindtap="goToNewsList">
        <text class="news-section-title">健康动态</text>
        <text class="news-more-btn">查看全部 ›</text>
      </view>
      <view wx:if="{{news.length > 0}}">
        <view class="news-row" wx:for="{{news}}" wx:key="id" bindtap="goToNews" data-id="{{item.id}}">
          <view class="news-dot-sm"></view>
          <text class="news-text-sm">{{item.title}}</text>
          <text class="news-arrow-sm">›</text>
        </view>
      </view>
      <view wx:else class="news-empty-sm">
        <text class="news-empty-text-sm">暂无动态，点击查看全部</text>
      </view>
    </view>

    </view><!-- /panel-body -->
  </view>

</view>

<global-alarm-overlay />
<staff-tabbar active="home" alarm-count="{{stats.todayAlarms}}" appt-count="{{stats.pendingAppts}}" />
