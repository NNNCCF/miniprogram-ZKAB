page {
  background: #3B7EFF;
  height: 100vh;
  overflow: hidden;
}

.map-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  padding-top: 180rpx;
  box-sizing: border-box;
}

.count-badge {
  position: fixed;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  background: rgba(59, 126, 255, 0.92);
  border-radius: 40rpx;
  padding: 16rpx 40rpx;
  backdrop-filter: blur(8px);
  z-index: 100;
}

.count-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.empty-tip {
  position: fixed;
  bottom: calc(60rpx + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  background: rgba(255,255,255,0.9);
  border-radius: 20rpx;
  padding: 16rpx 36rpx;
  z-index: 100;
}

.empty-text {
  font-size: 26rpx;
  color: #6B7280;
}
