<staff-navbar title="我的" show-back="{{false}}" />

<view class="page-body">

  <!-- Profile Card -->
  <view class="profile-card">
    <view class="avatar-wrap">
      <view class="avatar">
        <text class="avatar-text">{{avatarText}}</text>
      </view>
    </view>
    <view class="profile-info">
      <text class="profile-name">{{adminName}}</text>
      <text class="profile-org">{{orgName}}</text>
      <view class="role-tag">
        <text class="role-text">{{roleName}}</text>
      </view>
    </view>
  </view>

  <!-- Menu List -->
  <view class="menu-section">

    <!-- Group 1: Management -->
    <view class="menu-group">
      <view class="menu-item" bindtap="goToFamilyList">
        <view class="menu-icon-wrap menu-icon-orange">
          <text class="menu-icon-char">🏠</text>
        </view>
        <text class="menu-label">绑定家庭</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- Logout -->
    <view class="logout-btn" bindtap="onLogout">
      <text class="logout-text">退出登录</text>
    </view>

  </view>

</view>

<institution-tabbar active="profile" />
