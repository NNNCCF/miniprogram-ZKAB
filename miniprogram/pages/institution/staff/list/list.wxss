page {
  background: #3B7EFF;
  min-height: 100vh;
}

.page-body {
  background: #F2F5FC;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  min-height: calc(100vh - 180rpx);
  padding: 24rpx 0 calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  transform: translateY(32rpx);
}

.search-bar {
  padding: 0 28rpx 20rpx;
}

.search-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  border-radius: 40rpx;
  padding: 14rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(43, 107, 224, 0.08);
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
  opacity: 0.4;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  height: 44rpx;
}

.search-clear {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-icon {
  font-size: 28rpx;
  color: #bbb;
}

.list-count {
  padding: 0 28rpx 16rpx;
}

.count-text {
  font-size: 24rpx;
  color: #9CA3AF;
}

.nurse-list {
  padding: 0 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.nurse-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(43, 107, 224, 0.06);
}

.nurse-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1B3A70 0%, #3B7EFF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(59, 126, 255, 0.32);
}

.nurse-avatar-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 700;
}

.nurse-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.nurse-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0F1C38;
}

.nurse-role {
  font-size: 22rpx;
  color: #3B7EFF;
  background: #EBF1FF;
  display: inline-flex;
  align-self: flex-start;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.nurse-phone {
  font-size: 24rpx;
  color: #9CA3AF;
}

.empty-wrap,
.loading-wrap {
  padding: 80rpx 0;
  display: flex;
  justify-content: center;
}

.empty-text,
.loading-text {
  font-size: 28rpx;
  color: #ccc;
}
