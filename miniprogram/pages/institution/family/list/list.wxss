page {
  background: #3B7EFF;
  min-height: 100vh;
}

.page-body {
  background: #F2F5FC;
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
  min-height: calc(100vh - 180rpx);
  padding: 24rpx 0 40rpx;
  box-sizing: border-box;
  transform: translateY(32rpx);
}

.search-bar {
  padding: 0 28rpx 20rpx;
}

.search-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  border-radius: 40rpx;
  padding: 14rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(43, 107, 224, 0.08);
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
  opacity: 0.4;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  height: 44rpx;
}

.search-clear {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-icon {
  font-size: 28rpx;
  color: #bbb;
}

.list-count {
  padding: 0 28rpx 16rpx;
}

.count-text {
  font-size: 24rpx;
  color: #9CA3AF;
}

.family-list {
  padding: 0 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.family-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(43, 107, 224, 0.06);
}

.family-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #3B7EFF 0%, #5A9BFF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.family-avatar-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
}

.family-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.family-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #0F1C38;
}

.family-meta {
  font-size: 24rpx;
  color: #9CA3AF;
}

.family-addr {
  font-size: 22rpx;
  color: #bbb;
}

.empty-wrap,
.loading-wrap {
  padding: 80rpx 0;
  display: flex;
  justify-content: center;
}

.empty-text,
.loading-text {
  font-size: 28rpx;
  color: #ccc;
}
