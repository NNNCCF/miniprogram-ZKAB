.tabbar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  display: flex;
  border-top: 1rpx solid #F0F1F5;
  z-index: 100;
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0;
}
.icon-wrap {
  position: relative;
  width: 36rpx;
  height: 36rpx;
  margin-bottom: 6rpx;
}
.tab-icon {
  width: 36rpx;
  height: 36rpx;
}
.badge {
  position: absolute;
  top: -8rpx;
  right: -14rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  background: #FF4B4B;
  border-radius: 16rpx;
  font-size: 18rpx;
  color: #fff;
  text-align: center;
  box-sizing: border-box;
}
.tab-label {
  font-size: 20rpx;
  color: #9CA3AF;
}
.tab-item.active .tab-label {
  color: #3B7EFF;
  font-weight: 600;
}
