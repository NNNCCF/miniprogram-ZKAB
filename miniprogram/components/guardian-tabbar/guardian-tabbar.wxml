<view class="tabbar" style="padding-bottom: {{safeBottom}}px;">
  <view
    wx:for="{{tabs}}"
    wx:key="key"
    class="tab-item {{active === item.key ? 'active' : ''}}"
    bindtap="onTab"
    data-key="{{item.key}}"
    data-url="{{item.url}}"
  >
    <image class="tab-icon" src="{{active === item.key ? item.iconOn : item.icon}}" mode="aspectFit" />
    <text class="tab-label">{{item.label}}</text>
  </view>
</view>

<global-alarm-overlay />

<!-- 一键呼救弹窗 -->
<view class="sos-mask" wx:if="{{showSOS}}" bindtap="closeSOS">
  <view class="sos-panel" style="padding-bottom:calc({{safeBottom}}px + 32rpx)" catchtap="">
    <view class="sos-call-btn" bindtap="onSOSCall">
      <view class="sos-phone-wrap">
        <image class="sos-phone-icon" src="/images/客服电话.png" mode="aspectFit" />
      </view>
      <text class="sos-call-text">呼叫 0351-1234567</text>
    </view>
    <view class="sos-cancel-btn" bindtap="closeSOS">
      <text class="sos-cancel-text">取消</text>
    </view>
  </view>
</view>
