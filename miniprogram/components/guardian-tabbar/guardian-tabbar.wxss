.tabbar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  display: flex;
  border-top: 1rpx solid #F0F1F5;
  z-index: 100;
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0;
}
.tab-icon {
  width: 36rpx;
  height: 36rpx;
  margin-bottom: 6rpx;
}
.tab-label {
  font-size: 20rpx;
  color: #9CA3AF;
}
.tab-item.active .tab-label {
  color: #3B7EFF;
}

/* ===== SOS Modal ===== */
.sos-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(72, 72, 72, 0.57);
  z-index: 200;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.sos-panel {
  padding: 0 100rpx 100rpx;
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}
.sos-call-btn {
  background: #fff;
  border-radius: 32rpx;
  padding: 20rpx 36rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.25);
}
.sos-call-btn:active { background: #F5F8FF; }
.sos-phone-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #E8F3FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.sos-phone-icon {
  width: 44rpx;
  height: 44rpx;
}
.sos-call-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #0F1C38;
  letter-spacing: 1rpx;
}
.sos-cancel-btn {
  height:80rpx;
  background: #3a3a3a1e;
  border-radius: 32rpx;
  padding: 20rpx 36rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.25);
  align-items: center;
  justify-content: center;
}
.sos-cancel-btn:active { background: rgba(255, 255, 255, 0.22); }
.sos-cancel-text {
  font-size: 34rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.75);
}
