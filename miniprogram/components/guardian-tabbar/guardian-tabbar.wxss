.tabbar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  display: flex;
  border-top: 1rpx solid #F0F1F5;
  z-index: 100;
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0;
}
.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 6rpx;
}
.tab-label {
  font-size: 20rpx;
  color: #9CA3AF;
}
.tab-item.active .tab-label {
  color: #3B7EFF;
}
