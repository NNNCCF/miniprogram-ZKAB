.global-alarm-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  pointer-events: none;
}

.global-alarm-glow {
  position: absolute;
  inset: -120rpx;
  background: radial-gradient(circle at center, rgba(230, 58, 53, 0.38), rgba(230, 58, 53, 0.16) 42%, rgba(230, 58, 53, 0) 74%);
  animation: global-alarm-glow 1.8s ease-in-out infinite;
}

.global-alarm-glow.is-guardian {
  inset: -180rpx;
  background: radial-gradient(circle at center, rgba(239, 68, 68, 0.48), rgba(220, 38, 38, 0.28) 40%, rgba(127, 29, 29, 0.06) 72%, rgba(127, 29, 29, 0) 100%);
  animation: guardian-alarm-glow 1.1s ease-in-out infinite;
}

.global-alarm-panel {
  pointer-events: auto;
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 24rpx 80rpx rgba(127, 29, 29, 0.28);
  border: 1rpx solid rgba(254, 202, 202, 0.9);
  padding: 36rpx 32rpx 32rpx;
}

.global-alarm-panel.is-guardian {
  left: 40rpx;
  right: 40rpx;
  padding: 44rpx 36rpx 40rpx;
  border-radius: 40rpx;
  background:
    linear-gradient(180deg, rgba(127, 29, 29, 0.94), rgba(69, 10, 10, 0.96)),
    radial-gradient(circle at top, rgba(254, 226, 226, 0.22), rgba(127, 29, 29, 0));
  border: 2rpx solid rgba(254, 202, 202, 0.18);
  box-shadow: 0 28rpx 90rpx rgba(69, 10, 10, 0.56);
}

.global-alarm-badge {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #fff1f2;
  color: #e63a35;
  font-size: 22rpx;
  font-weight: 700;
}

.global-alarm-title {
  margin-top: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #161b26;
  line-height: 1.35;
}

.global-alarm-card {
  margin-top: 24rpx;
  padding: 8rpx 0;
  border-radius: 24rpx;
  background: #f8fafc;
}

.global-alarm-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 16rpx 24rpx;
}

.global-alarm-key {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #7b8794;
}

.global-alarm-value {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
  font-weight: 600;
  color: #162033;
  line-height: 1.45;
}

.global-alarm-desc {
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #5b6576;
}

.global-alarm-result-label {
  margin-top: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #5b6576;
}

.global-alarm-result-group {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.global-alarm-result-item {
  flex: 1;
  height: 84rpx;
  border-radius: 24rpx;
  border: 2rpx solid #fecaca;
  background: #fff5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #991b1b;
  font-size: 28rpx;
  font-weight: 700;
}

.global-alarm-result-item.is-selected {
  background: linear-gradient(135deg, #e63a35, #bf2622);
  border-color: #e63a35;
  color: #ffffff;
  box-shadow: 0 18rpx 36rpx rgba(230, 58, 53, 0.24);
}

.global-alarm-close {
  margin-top: 24rpx;
  height: 88rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #141927, #20293c);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.global-alarm-close.is-disabled {
  opacity: 0.46;
}

.guardian-alarm-shell {
  position: relative;
  height: 420rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.guardian-alarm-ring {
  position: absolute;
  border-radius: 999rpx;
  border: 4rpx solid rgba(254, 202, 202, 0.54);
}

.guardian-alarm-ring-outer {
  width: 392rpx;
  height: 392rpx;
  box-shadow: 0 0 0 16rpx rgba(248, 113, 113, 0.06);
  animation: guardian-ring-outer 1.2s ease-out infinite;
}

.guardian-alarm-ring-middle {
  width: 324rpx;
  height: 324rpx;
  border-color: rgba(254, 226, 226, 0.72);
  animation: guardian-ring-middle 1.2s ease-in-out infinite;
}

.guardian-alarm-core {
  position: relative;
  z-index: 1;
  width: 272rpx;
  height: 272rpx;
  border-radius: 999rpx;
  padding: 34rpx 24rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0)),
    linear-gradient(180deg, #ef4444, #991b1b);
  box-shadow:
    inset 0 10rpx 24rpx rgba(255, 255, 255, 0.18),
    inset 0 -18rpx 40rpx rgba(69, 10, 10, 0.28),
    0 18rpx 48rpx rgba(69, 10, 10, 0.42);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  animation: guardian-core-pulse 1.2s ease-in-out infinite;
}

.guardian-alarm-badge {
  padding: 0 18rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #fee2e2;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 40rpx;
  letter-spacing: 2rpx;
}

.guardian-alarm-title {
  margin-top: 20rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.4;
}

.guardian-alarm-time {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
  line-height: 1.4;
}

.guardian-alarm-location {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  line-height: 1.5;
}

.guardian-alarm-note {
  margin-top: 8rpx;
  text-align: center;
  color: rgba(254, 242, 242, 0.86);
  font-size: 24rpx;
  line-height: 1.7;
}

.guardian-alarm-button {
  margin-top: 28rpx;
  height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #fff1f2, #fecdd3);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9f1239;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  box-shadow: 0 16rpx 36rpx rgba(127, 29, 29, 0.28);
}

.guardian-alarm-button.is-disabled {
  opacity: 0.58;
}

@keyframes global-alarm-glow {
  0%, 100% {
    opacity: 0.58;
    transform: scale(1);
  }
  50% {
    opacity: 0.96;
    transform: scale(1.04);
  }
}

@keyframes guardian-alarm-glow {
  0%, 100% {
    opacity: 0.52;
    transform: scale(0.98);
  }
  50% {
    opacity: 1;
    transform: scale(1.06);
  }
}

@keyframes guardian-ring-outer {
  0% {
    opacity: 0.96;
    transform: scale(0.92);
  }
  70% {
    opacity: 0.16;
    transform: scale(1.08);
  }
  100% {
    opacity: 0;
    transform: scale(1.14);
  }
}

@keyframes guardian-ring-middle {
  0%, 100% {
    opacity: 0.82;
    transform: scale(0.98);
  }
  50% {
    opacity: 0.34;
    transform: scale(1.08);
  }
}

@keyframes guardian-core-pulse {
  0%, 100% {
    transform: scale(0.98);
  }
  50% {
    transform: scale(1.03);
  }
}
